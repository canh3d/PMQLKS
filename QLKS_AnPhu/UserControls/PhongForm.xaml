<Window x:Class="QLKS_AnPhu.View.PhongForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin phòng"
        Width="560"
        Height="560"
        MinWidth="520"
        MinHeight="530"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FB">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTieuDe"
                   Text="Thêm phòng"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#0F1F33" />

        <Grid Grid.Row="1" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Số phòng" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="TxtSoPhong" Height="34" Padding="8,0" VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="2">
                <TextBlock Text="Tầng" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="TxtTang" Height="34" Padding="8,0" VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,14,0,0">
                <TextBlock Text="Loại phòng" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox x:Name="CboLoaiPhong" Height="34" SelectionChanged="CboLoaiPhong_SelectionChanged">
                    <ComboBoxItem Content="Phòng đơn" />
                    <ComboBoxItem Content="Phòng đôi" />
                    <ComboBoxItem Content="Phòng VIP" />
                </ComboBox>
            </StackPanel>

            <TextBox x:Name="TxtLoaiPhong" Visibility="Collapsed" />

            <StackPanel Grid.Row="2" Margin="0,14,0,0">
                <TextBlock Text="Giá giờ" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="TxtGiaGio" Height="34" Padding="8,0" VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,14,0,0">
                <TextBlock Text="Giá ngày" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="TxtGiaNgay" Height="34" Padding="8,0" VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,14,0,0">
                <TextBlock Text="Giá đêm" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="TxtGiaDem" Height="34" Padding="8,0" VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,14,0,0">
                <TextBlock Text="Trạng thái" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox x:Name="CboTrangThai" Height="34" SelectedIndex="0">
                    <ComboBoxItem Content="Phòng trống" />
                    <ComboBoxItem Content="Đang thuê" />
                    <ComboBoxItem Content="Đang sửa chữa" />
                    <ComboBoxItem Content="Đã đặt" />
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Margin="0,14,0,0">
                <TextBlock Text="Ghi chú" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBox x:Name="TxtGhiChu" Height="90" Padding="8" AcceptsReturn="True" TextWrapping="Wrap" />
            </StackPanel>

            <TextBlock x:Name="TxtThongBao"
                       Grid.Row="5"
                       Grid.ColumnSpan="3"
                       Margin="0,14,0,0"
                       Foreground="#D92D20"
                       TextWrapping="Wrap" />
        </Grid>

        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Content="Hủy" Width="96" Height="36" Background="White" BorderBrush="#C9D3E3" Click="BtnHuy_Click" />
            <Button Content="Lưu" Width="112" Height="36" Margin="10,0,0,0" Background="#0B55C7" BorderBrush="#0B55C7" Foreground="White" FontWeight="SemiBold" Click="BtnLuu_Click" />
        </StackPanel>
    </Grid>
</Window>
