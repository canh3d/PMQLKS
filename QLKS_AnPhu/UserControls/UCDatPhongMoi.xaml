<UserControl x:Class="QLKS_AnPhu.UserControls.UCDatPhongMoi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="1100"
             Background="White">
    <UserControl.Resources>
        <DropShadowEffect x:Key="PanelShadow" BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.16" />

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="25" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="BorderBrush" Value="#BBC3D0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="25" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#BBC3D0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InputDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="25" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderBrush" Value="#BBC3D0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="BorderBrush" Value="#D7DCE5" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="QuickHourButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#075985" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </UserControl.Resources>

    <Border Background="White" Padding="24,20,24,16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Đặt phòng mới"
                       VerticalAlignment="Top"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#111827" />

            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnDatTheoNgay"
                        Grid.Column="0"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#2563EB"
                        BorderBrush="#2563EB"
                        Foreground="White"
                        Click="BtnDatTheoNgay_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="WhiteBalanceSunny" Width="14" Height="14" Margin="0,0,7,0" />
                        <TextBlock Text="Đặt phòng theo ngày" />
                    </StackPanel>
                </Button>

                <Button x:Name="BtnDatQuaDem"
                        Grid.Column="2"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#F2F4F7"
                        BorderBrush="#D0D5DD"
                        Foreground="#8B95A5"
                        Click="BtnDatQuaDem_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="WeatherNight" Width="14" Height="14" Margin="0,0,7,0" />
                        <TextBlock Text="Đặt phòng qua đêm" />
                    </StackPanel>
                </Button>

                <Button x:Name="BtnDatTheoGio"
                        Grid.Column="4"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#F2F4F7"
                        BorderBrush="#D0D5DD"
                        Foreground="#8B95A5"
                        Click="BtnDatTheoGio_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="ClockOutline" Width="14" Height="14" Margin="0,0,7,0" />
                        <TextBlock Text="Đặt phòng theo giờ" />
                    </StackPanel>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.35*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <GroupBox Header="THÔNG TIN KHÁCH HÀNG" Style="{StaticResource GroupBoxStyle}" Effect="{StaticResource PanelShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="76" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="78" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="34" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Họ tên" VerticalAlignment="Center" FontWeight="Normal" />
                                <TextBox x:Name="TxtHoTen" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />
                                <TextBlock Grid.Column="2" Text="Giới tính" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Normal" />
                                <ComboBox x:Name="CboGioiTinh" Grid.Column="3" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0">
                                    <ComboBoxItem Content="Nam" />
                                    <ComboBoxItem Content="Nữ" />
                                </ComboBox>

                                <TextBlock Grid.Row="1" Text="SDT" VerticalAlignment="Center" FontWeight="Normal" />
                                <TextBox x:Name="TxtSDT" Grid.Row="1" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Ngày sinh" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Normal" />
                                <DatePicker x:Name="DpNgaySinh" Grid.Row="1" Grid.Column="3" Style="{StaticResource InputDatePickerStyle}" />

                                <TextBlock Grid.Row="2" Text="CCCD" VerticalAlignment="Center" FontWeight="Normal" />
                                <TextBox x:Name="TxtCCCD" Grid.Row="2" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Text="Địa chỉ" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Normal" />
                                <TextBox x:Name="TxtDiaChi" Grid.Row="2" Grid.Column="3" Style="{StaticResource InputTextBoxStyle}" />

                                <TextBlock Grid.Row="3" Text="Loại khách" VerticalAlignment="Center" FontWeight="Normal" />
                                <ComboBox x:Name="CboLoaiKhach" Grid.Row="3" Grid.Column="1" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0">
                                    <ComboBoxItem Content="Thường" />
                                    <ComboBoxItem Content="VIP" />
                                    <ComboBoxItem Content="Khách đoàn" />
                                </ComboBox>
                            </Grid>
                        </GroupBox>

                        <GroupBox x:Name="GrpThongTinDatPhong"
                                  Header="THÔNG TIN ĐẶT PHÒNG THEO NGÀY"
                                  Margin="0,18,0,0"
                                  Style="{StaticResource GroupBoxStyle}"
                                  Effect="{StaticResource PanelShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="126" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="34" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Loại phòng" VerticalAlignment="Center" FontWeight="Normal" />
                                <ComboBox x:Name="CboLoaiPhong" Grid.Column="1" Style="{StaticResource InputComboBoxStyle}" SelectionChanged="CboLoaiPhong_SelectionChanged" />

                                <TextBlock Grid.Row="1" Text="Phòng" VerticalAlignment="Center" FontWeight="Normal" />
                                <ComboBox x:Name="CboPhong" Grid.Row="1" Grid.Column="1" Style="{StaticResource InputComboBoxStyle}" DisplayMemberPath="MaHienThi" SelectionChanged="CboPhong_SelectionChanged" />

                                <TextBlock Grid.Row="2" Text="Loại đặt phòng" VerticalAlignment="Center" FontWeight="Normal" />
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <RadioButton x:Name="RbDatTruoc"
                                                 Content="Đặt trước"
                                                 GroupName="LoaiDatPhong"
                                                 IsChecked="True"
                                                 FontWeight="SemiBold"
                                                 Checked="LoaiDatPhong_Changed" />
                                    <RadioButton x:Name="RbNhanNgay"
                                                 Content="Nhận ngay"
                                                 GroupName="LoaiDatPhong"
                                                 Margin="28,0,0,0"
                                                 FontWeight="SemiBold"
                                                 Checked="LoaiDatPhong_Changed" />
                                </StackPanel>

                                <TextBlock x:Name="LblNgayNhan" Grid.Row="3" Text="Ngày nhận" VerticalAlignment="Center" FontWeight="Normal" />
                                <Grid x:Name="PanelNgayNhan" Grid.Row="3" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="92" />
                                    </Grid.ColumnDefinitions>
                                    <DatePicker x:Name="DpNgayNhan" Style="{StaticResource InputDatePickerStyle}" SelectedDateChanged="TinhTien_Changed" />
                                    <Grid Grid.Column="2">
                                        <TextBox x:Name="TxtGioNhanNgay"
                                                 Style="{StaticResource InputTextBoxStyle}"
                                                 Text="14:00"
                                                 Padding="6,0,26,0"
                                                 TextChanged="TinhTien_Changed" />
                                        <iconPacks:PackIconMaterial Kind="ClockOutline"
                                                                    Width="15"
                                                                    Height="15"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,7,0"
                                                                    Foreground="#64748B" />
                                    </Grid>
                                </Grid>
                                <TextBox x:Name="TxtGioNhan"
                                         Grid.Row="3"
                                         Grid.Column="1"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         Visibility="Collapsed"
                                         TextChanged="TinhTien_Changed" />

                                <TextBlock x:Name="LblNgayTra" Grid.Row="4" Text="Ngày trả" VerticalAlignment="Center" FontWeight="Normal" />
                                <Grid x:Name="PanelNgayTra" Grid.Row="4" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="92" />
                                    </Grid.ColumnDefinitions>
                                    <DatePicker x:Name="DpNgayTra" Style="{StaticResource InputDatePickerStyle}" SelectedDateChanged="TinhTien_Changed" />
                                    <Grid Grid.Column="2">
                                        <TextBox x:Name="TxtGioTraNgay"
                                                 Style="{StaticResource InputTextBoxStyle}"
                                                 Text="12:00"
                                                 Padding="6,0,26,0"
                                                 TextChanged="TinhTien_Changed" />
                                        <iconPacks:PackIconMaterial Kind="ClockOutline"
                                                                    Width="15"
                                                                    Height="15"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,7,0"
                                                                    Foreground="#64748B" />
                                    </Grid>
                                </Grid>
                                <Grid x:Name="PanelDatTheoGio" Grid.Row="4" Grid.Column="1" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtSoGioThue" Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" Text="2" TextChanged="TinhTien_Changed" />
                                    <Button Grid.Column="2" Style="{StaticResource QuickHourButtonStyle}" Content="1h" Click="BtnQuickHour_Click" />
                                    <Button Grid.Column="4" Style="{StaticResource QuickHourButtonStyle}" Content="2h" Click="BtnQuickHour_Click" />
                                    <Button Grid.Column="6" Style="{StaticResource QuickHourButtonStyle}" Content="3h" Click="BtnQuickHour_Click" />
                                    <Button Grid.Column="8" Style="{StaticResource QuickHourButtonStyle}" Content="6h" Click="BtnQuickHour_Click" />
                                </Grid>

                                <TextBlock Grid.Row="5" Text="Số người" VerticalAlignment="Center" FontWeight="Normal" />
                                <TextBox x:Name="TxtSoNguoi" Grid.Row="5" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Text="1" />

                                <TextBlock x:Name="LblDatCoc" Grid.Row="6" Text="Đặt cọc" VerticalAlignment="Center" FontWeight="Normal" />
                                <TextBox x:Name="TxtDatCoc" Grid.Row="6" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" Text="0" TextChanged="TinhTien_Changed" />
                            </Grid>
                        </GroupBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <GroupBox Header="THÊM DỊCH VỤ VÀO PHÒNG" Style="{StaticResource GroupBoxStyle}" Effect="{StaticResource PanelShadow}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="210" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="88" />
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="CboDichVu" Grid.Column="0" Style="{StaticResource InputComboBoxStyle}" DisplayMemberPath="Ten" />
                                <TextBox x:Name="TxtSoLuongDichVu" Grid.Column="1" Margin="8,0,0,0" Style="{StaticResource InputTextBoxStyle}" Text="1" />
                                <Button Grid.Column="2" Margin="8,0,0,0" Height="26" Background="#087987" BorderBrush="#087987" Foreground="White" Click="BtnThemDichVu_Click">
                                    <TextBlock Text="Thêm" />
                                </Button>

                                <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Text="Dịch vụ đã thêm" VerticalAlignment="Center" FontWeight="SemiBold" />

                                <DataGrid x:Name="DgDichVuDaThem"
                                          Grid.Row="2"
                                          Grid.ColumnSpan="3"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          RowHeight="28"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Height" Value="28" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="Background" Value="#F2F4F7" />
                                            <Setter Property="BorderBrush" Value="#D0D5DD" />
                                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Tên dịch vụ" Binding="{Binding Ten}" Width="*" />
                                        <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="48" />
                                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia, StringFormat={}{0:N0}}" Width="86" />
                                        <DataGridTextColumn Header="Thành tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="96" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="TỔNG TẠM TÍNH TIỀN THANH TOÁN"
                                  Margin="0,18,0,0"
                                  Style="{StaticResource GroupBoxStyle}"
                                  Background="#F1F7FF"
                                  Effect="{StaticResource PanelShadow}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="30" />
                                    <RowDefinition Height="42" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="TxtTienPhong" Text="Tiền phòng: 0 đ" />
                                <TextBlock x:Name="TxtTienDichVu" Grid.Row="1" Text="Tiền dịch vụ: 0 đ" />
                                <TextBlock x:Name="TxtTienDatCoc" Grid.Row="2" Text="Đặt cọc: 0 đ" />
                                <TextBlock x:Name="TxtTongThanhToan" Grid.Row="3" Text="Tổng thanh toán: 0 đ" FontSize="18" FontWeight="Bold" Foreground="#064E5A" />
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Orientation="Horizontal">
                <Button Style="{StaticResource ActionButtonStyle}" Background="#22C55E" BorderBrush="#22C55E" Foreground="White" Click="BtnLuu_Click">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" Margin="0,0,7,0" />
                        <TextBlock Text="Lưu đặt phòng" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ActionButtonStyle}" Margin="12,0,0,0" Background="#F2F4F7" BorderBrush="#D0D5DD" Foreground="#344054" Click="BtnLamMoi_Click">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,7,0" />
                        <TextBlock Text="Làm mới" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ActionButtonStyle}" Margin="12,0,0,0" Background="#667085" BorderBrush="#667085" Foreground="White" Click="BtnDong_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="X" Margin="0,0,7,0" />
                        <TextBlock Text="Đóng" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
