<UserControl x:Class="QLKS_AnPhu.UserControls.UCPhong"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="128"
             d:DesignWidth="142">
    <Border x:Name="RootBorder"
            Width="142"
            Height="128"
            Margin="0,0,12,12"
            Padding="12"
            Background="#ECFDF3"
            BorderBrush="#6EC491"
            BorderThickness="1"
            CornerRadius="7"
            Cursor="Hand"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown">
        <Grid>
            <StackPanel>
                <DockPanel>
                    <TextBlock x:Name="TxtMaPhong"
                               Text="P101"
                               FontSize="21"
                               FontWeight="Bold"
                               Foreground="#0D9E4D"
                               DockPanel.Dock="Left" />
                    <iconPacks:PackIconMaterial x:Name="IconStar"
                                                Kind="Star"
                                                Width="14"
                                                Height="14"
                                                Foreground="#087987"
                                                HorizontalAlignment="Right"
                                                Visibility="Collapsed" />
                </DockPanel>
                <TextBlock x:Name="TxtTrangThai"
                           Text="Phòng trống"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#0D9E4D"
                           Margin="0,6,0,0"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="TxtLoaiPhong"
                           Text="Phòng đơn"
                           FontSize="12"
                           Foreground="#344054"
                           Margin="0,6,0,0"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="TxtGiaPhong"
                           Text="450,000 đ"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,4,0,0" />
            </StackPanel>

            <TextBlock x:Name="TxtDonDep"
                       Text="Đã dọn dẹp"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Left"
                       MaxWidth="92"
                       FontSize="10"
                       Foreground="#475467"
                       TextTrimming="CharacterEllipsis" />
            <iconPacks:PackIconMaterial Kind="Bed"
                                        Width="22"
                                        Height="22"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Foreground="#475467" />
        </Grid>
    </Border>
</UserControl>
