<Window x:Class="QLKS_AnPhu.View.DichVuVatTuForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dịch vụ - vật tư"
        Width="680"
        Height="760"
        MinWidth="620"
        MinHeight="700"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="36" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#C9D3E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="TxtTieuDe"
                       Text="Thêm dịch vụ"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#0F1F33" />
            <TextBlock Text="Nhập thông tin dịch vụ hoặc vật tư"
                       Margin="0,8,0,0"
                       Foreground="#667085" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,24,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Tên dịch vụ/vật tư" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="TxtTen" Style="{StaticResource InputStyle}" Padding="9,0" VerticalContentAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,14,0,0">
                <TextBlock Text="Loại" Style="{StaticResource LabelStyle}" />
                <ComboBox x:Name="CboLoai" Style="{StaticResource InputStyle}" SelectedIndex="0">
                    <ComboBoxItem Content="Dịch vụ" />
                    <ComboBoxItem Content="Vật tư" />
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,14,0,0">
                <TextBlock Text="Đơn vị tính" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="TxtDonViTinh" Style="{StaticResource InputStyle}" Padding="9,0" VerticalContentAlignment="Center" />
            </StackPanel>

            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Đơn giá" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="TxtDonGia" Style="{StaticResource InputStyle}" Padding="9,0" VerticalContentAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Số lượng tồn" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="TxtSoLuongTon" Style="{StaticResource InputStyle}" Padding="9,0" VerticalContentAlignment="Center" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="4" Margin="0,14,0,0">
                <TextBlock Text="Trạng thái" Style="{StaticResource LabelStyle}" />
                <ComboBox x:Name="CboTrangThai" Style="{StaticResource InputStyle}" SelectedIndex="0">
                    <ComboBoxItem Content="Còn hàng" />
                    <ComboBoxItem Content="Sắp hết" />
                    <ComboBoxItem Content="Hết hàng" />
                    <ComboBoxItem Content="Ngừng dùng" />
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="5" Margin="0,14,0,0">
                <TextBlock Text="Ghi chú" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="TxtGhiChu"
                         Height="82"
                         Padding="9"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />
            </StackPanel>

            <TextBlock x:Name="TxtThongBao"
                       Grid.Row="6"
                       Margin="0,12,0,0"
                       Foreground="#D92D20"
                       TextWrapping="Wrap" />
        </Grid>

        <StackPanel Grid.Row="2"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Content="Hủy"
                    Width="92"
                    Height="36"
                    Background="White"
                    BorderBrush="#C9D3E3"
                    Click="BtnHuy_Click" />
            <Button Content="Lưu"
                    Width="110"
                    Height="36"
                    Margin="10,0,0,0"
                    Background="#0B55C7"
                    BorderBrush="#0B55C7"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Click="BtnLuu_Click" />
        </StackPanel>
    </Grid>
</Window>
