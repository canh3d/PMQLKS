<UserControl x:Class="QLKS_AnPhu.UserControls.UCDatPhongTheoDoan"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1450"
             Background="White">
    <UserControl.Resources>
        <DropShadowEffect x:Key="PanelShadow" BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.16" />

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>

        <Style x:Key="InputDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#0F766E" />
            <Setter Property="BorderBrush" Value="#0F766E" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#DC2626" />
            <Setter Property="BorderBrush" Value="#DC2626" />
        </Style>
    </UserControl.Resources>

    <Border Padding="24,20,24,16" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <StackPanel>
                    <TextBlock Text="Đặt phòng cho đoàn" FontSize="25" FontWeight="Bold" Foreground="#111827" />
                    <TextBlock Text="Chọn nhiều phòng trống, thêm dịch vụ và tạo phiếu đặt/thuê bằng dữ liệu thật trong database"
                               Margin="0,5,0,0" Foreground="#475569" FontSize="13" />
                </StackPanel>
                <TextBlock x:Name="TxtTrangThai" HorizontalAlignment="Right" VerticalAlignment="Top"
                           Foreground="#0F766E" FontWeight="SemiBold" />
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="335" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" MinWidth="560" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="430" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6"
                                Padding="16" Effect="{StaticResource PanelShadow}">
                            <StackPanel>
                                <TextBlock Text="Thông tin đại diện đoàn" FontSize="17" FontWeight="Bold" Foreground="#111827" />

                                <TextBlock Text="Tên đoàn / khách đại diện" Margin="0,12,0,5" FontWeight="SemiBold" />
                                <TextBox x:Name="TxtTenDaiDien" Style="{StaticResource InputTextBoxStyle}" />

                                <TextBlock Text="Số điện thoại" Margin="0,10,0,5" FontWeight="SemiBold" />
                                <TextBox x:Name="TxtSDT" Style="{StaticResource InputTextBoxStyle}" />

                                <TextBlock Text="CCCD / MST" Margin="0,10,0,5" FontWeight="SemiBold" />
                                <TextBox x:Name="TxtCCCD" Style="{StaticResource InputTextBoxStyle}" />

                                <TextBlock Text="Địa chỉ" Margin="0,10,0,5" FontWeight="SemiBold" />
                                <TextBox x:Name="TxtDiaChi" Style="{StaticResource InputTextBoxStyle}" />

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Giới tính" Margin="0,0,0,5" FontWeight="SemiBold" />
                                        <ComboBox x:Name="CboGioiTinh" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="0">
                                            <ComboBoxItem Content="Nam" />
                                            <ComboBoxItem Content="Nữ" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Loại khách" Margin="0,0,0,5" FontWeight="SemiBold" />
                                        <ComboBox x:Name="CboLoaiKhach" Style="{StaticResource InputComboBoxStyle}" SelectedIndex="2">
                                            <ComboBoxItem Content="Thường" />
                                            <ComboBoxItem Content="VIP" />
                                            <ComboBoxItem Content="Khách đoàn" />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Ghi chú đoàn" Margin="0,10,0,5" FontWeight="SemiBold" />
                                <TextBox x:Name="TxtGhiChu" Height="54" AcceptsReturn="True" TextWrapping="Wrap"
                                         Padding="8" BorderBrush="#CBD5E1" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                CornerRadius="6" Padding="16" Effect="{StaticResource PanelShadow}">
                            <StackPanel>
                                <TextBlock Text="Thông tin đặt phòng" FontSize="17" FontWeight="Bold" Foreground="#111827" />

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <RadioButton x:Name="RbDatTruoc" Content="Đặt trước" GroupName="LoaiDatDoan"
                                                 IsChecked="True" FontWeight="SemiBold" Checked="ThongTinDatPhong_Changed" />
                                    <RadioButton x:Name="RbNhanNgay" Content="Nhận ngay" GroupName="LoaiDatDoan"
                                                 Margin="24,0,0,0" FontWeight="SemiBold" Checked="ThongTinDatPhong_Changed" />
                                </StackPanel>

                                <TextBlock Text="Ngày nhận dự kiến" Margin="0,12,0,5" FontWeight="SemiBold" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="86" />
                                    </Grid.ColumnDefinitions>
                                    <DatePicker x:Name="DpNgayNhan" Style="{StaticResource InputDatePickerStyle}"
                                                SelectedDateChanged="ThongTinDatPhong_Changed" />
                                    <Grid Grid.Column="2">
                                        <TextBox x:Name="TxtGioNhan" Text="14:00" Style="{StaticResource InputTextBoxStyle}"
                                                 Padding="8,0,28,0" TextChanged="ThongTinDatPhong_Changed" />
                                        <iconPacks:PackIconMaterial Kind="ClockOutline" Width="16" Height="16"
                                                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                    Margin="0,0,8,0" Foreground="#64748B" />
                                    </Grid>
                                </Grid>

                                <TextBlock Text="Ngày trả dự kiến" Margin="0,10,0,5" FontWeight="SemiBold" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="86" />
                                    </Grid.ColumnDefinitions>
                                    <DatePicker x:Name="DpNgayTra" Style="{StaticResource InputDatePickerStyle}"
                                                SelectedDateChanged="ThongTinDatPhong_Changed" />
                                    <Grid Grid.Column="2">
                                        <TextBox x:Name="TxtGioTra" Text="12:00" Style="{StaticResource InputTextBoxStyle}"
                                                 Padding="8,0,28,0" TextChanged="ThongTinDatPhong_Changed" />
                                        <iconPacks:PackIconMaterial Kind="ClockOutline" Width="16" Height="16"
                                                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                    Margin="0,0,8,0" Foreground="#64748B" />
                                    </Grid>
                                </Grid>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Số người" Margin="0,0,0,5" FontWeight="SemiBold" />
                                        <TextBox x:Name="TxtSoNguoi" Text="1" Style="{StaticResource InputTextBoxStyle}"
                                                 TextChanged="ThongTinDatPhong_Changed" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Tổng đặt cọc" Margin="0,0,0,5" FontWeight="SemiBold" />
                                        <TextBox x:Name="TxtDatCoc" Text="0" Style="{StaticResource InputTextBoxStyle}"
                                                 TextChanged="ThongTinDatPhong_Changed" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="6" Padding="16" Effect="{StaticResource PanelShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="128" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <TextBlock Text="Danh sách phòng trống" FontSize="17" FontWeight="Bold"
                                       Foreground="#111827" VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButtonStyle}" Click="BtnChonTatCa_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="CheckboxMultipleMarkedOutline" Width="15" Height="15" Margin="0,0,6,0" />
                                        <TextBlock Text="Chọn tất cả" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="BtnBoChon_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <iconPacks:PackIconMaterial Kind="CloseBoxMultipleOutline" Width="15" Height="15" Margin="0,0,6,0" />
                                        <TextBlock Text="Bỏ chọn" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <DataGrid x:Name="DgPhong" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                                  CanUserDeleteRows="False" IsReadOnly="False" HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal" RowHeight="30" FontSize="13"
                                  SelectionMode="Extended" BorderBrush="#CBD5E1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  SelectionChanged="DgPhong_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Chọn" Width="52">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding Chon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" Checked="PhongSelection_Changed"
                                                      Unchecked="PhongSelection_Changed" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Phòng" Binding="{Binding Phong.MaHienThi}" Width="68" IsReadOnly="True" />
                                <DataGridTextColumn Header="Tầng" Binding="{Binding Phong.Tang}" Width="52" IsReadOnly="True" />
                                <DataGridTextColumn Header="Loại phòng" Binding="{Binding Phong.LoaiPhong}" Width="130" IsReadOnly="True" />
                                <DataGridTextColumn Header="Giá ngày" Binding="{Binding GiaNgayHienThi}" Width="88" IsReadOnly="True" />
                                <DataGridTextColumn Header="Giá đêm" Binding="{Binding GiaDemHienThi}" Width="88" IsReadOnly="True" />
                                <DataGridTextColumn Header="Giá giờ" Binding="{Binding GiaGioHienThi}" Width="84" IsReadOnly="True" />
                                <DataGridTextColumn Header="Trạng thái" Binding="{Binding Phong.TrangThai}" Width="100" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2" Margin="0,12,0,0" Background="#EFF6FF" BorderBrush="#BFDBFE"
                                BorderThickness="1" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Số phòng đã chọn" Foreground="#475569" />
                                    <TextBlock x:Name="TxtSoPhongChon" Text="0 phòng" FontSize="19" FontWeight="Bold" Foreground="#111827" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Tiền phòng" Foreground="#475569" />
                                    <TextBlock x:Name="TxtTienPhong" Text="0 VND" FontSize="19" FontWeight="Bold" Foreground="#0F766E" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Tiền dịch vụ" Foreground="#475569" />
                                    <TextBlock x:Name="TxtTienDichVu" Text="0 VND" FontSize="19" FontWeight="Bold" Foreground="#0369A1" />
                                </StackPanel>
                                <StackPanel Grid.Row="1">
                                    <TextBlock Text="Cọc gợi ý" Foreground="#475569" />
                                    <TextBlock x:Name="TxtCocGoiY" Text="0 VND" FontSize="19" FontWeight="Bold" Foreground="#B45309" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
                                    <TextBlock Text="Tổng tạm tính" Foreground="#475569" />
                                    <TextBlock x:Name="TxtTongTamTinh" Text="0 VND" FontSize="22" FontWeight="Bold" Foreground="#0F172A" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="4" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="6" Padding="16" Effect="{StaticResource PanelShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="38" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="42" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Thêm dịch vụ vào đoàn" FontSize="17" FontWeight="Bold"
                                   Foreground="#111827" VerticalAlignment="Center" />
                        <TextBlock x:Name="TxtPhongDangThem"
                                   Grid.Row="1"
                                   Text="Chọn một phòng để thêm dịch vụ"
                                   Foreground="#0F766E"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="82" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="CboDichVuDoan" DisplayMemberPath="Ten" Style="{StaticResource InputComboBoxStyle}" />
                            <TextBox x:Name="TxtSoLuongDichVu" Grid.Column="2" Text="1" Style="{StaticResource InputTextBoxStyle}" />
                            <Button Grid.Column="4" Style="{StaticResource ActionButtonStyle}" Click="BtnThemDichVu_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="PlusCircle" Width="14" Height="14" Margin="0,0,5,0" />
                                    <TextBlock Text="Thêm" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <DataGrid x:Name="DgDichVuDoan" Grid.Row="3" Margin="0,10,0,0"
                                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                  IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowHeight="30" FontSize="13" BorderBrush="#CBD5E1"
                                  MouseDoubleClick="DgDichVuDoan_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tên dịch vụ" Binding="{Binding Ten}" Width="*" />
                                <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="42" />
                                <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGiaHienThi}" Width="82" />
                                <DataGridTextColumn Header="Thành tiền" Binding="{Binding ThanhTienHienThi}" Width="92" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Row="4" Margin="0,10,0,0">
                            <TextBlock x:Name="TxtTongDichVu" Text="Tổng dịch vụ: 0 VND"
                                       VerticalAlignment="Center" FontWeight="Bold" Foreground="#0369A1" />
                            <Button HorizontalAlignment="Right" Style="{StaticResource DangerButtonStyle}" Click="BtnXoaDichVu_Click">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" Margin="0,0,5,0" />
                                    <TextBlock Text="Xóa" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource ActionButtonStyle}" Click="BtnLuu_Click">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="16" Height="16" Margin="0,0,7,0" />
                            <TextBlock Text="Lưu đặt đoàn" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="12,0,0,0" Click="BtnLamMoi_Click">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="16" Height="16" Margin="0,0,7,0" />
                            <TextBlock Text="Làm mới" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DangerButtonStyle}" Margin="12,0,0,0" Click="BtnDong_Click">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,7,0" />
                            <TextBlock Text="Đóng" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
