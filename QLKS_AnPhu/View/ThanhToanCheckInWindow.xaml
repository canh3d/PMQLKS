<Window x:Class="QLKS_AnPhu.View.ThanhToanCheckInWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Thanh toán nhận phòng" Width="720" Height="650"
        MinWidth="720" MinHeight="650" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="#F8FAFC">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Thanh toán khi nhận phòng" FontSize="24" FontWeight="Bold" Foreground="#0F172A" />
            <TextBlock x:Name="TxtMoTa" Margin="0,7,0,0" FontSize="15" Foreground="#475569" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,22,0,22" Padding="20" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="46" />
                    <RowDefinition Height="46" />
                    <RowDefinition Height="46" />
                    <RowDefinition Height="46" />
                    <RowDefinition Height="46" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Tiền phòng" VerticalAlignment="Center" Foreground="#334155" />
                <TextBlock x:Name="TxtTienPhong" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" />
                <TextBlock Grid.Row="1" Text="Dịch vụ tại check-in" VerticalAlignment="Center" Foreground="#334155" />
                <TextBlock x:Name="TxtTienDichVu" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" />
                <TextBlock Grid.Row="2" Text="Phụ phí nhận sớm" VerticalAlignment="Center" Foreground="#334155" />
                <TextBlock x:Name="TxtPhuPhi" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" />
                <TextBlock Grid.Row="3" Text="Giảm giá" VerticalAlignment="Center" Foreground="#334155" />
                <TextBlock x:Name="TxtGiamGia" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" />
                <TextBlock Grid.Row="4" Text="Thuế VAT (10%)" VerticalAlignment="Center" Foreground="#334155" />
                <TextBlock x:Name="TxtThueVat" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" />
                <TextBlock Grid.Row="5" Text="Đã đặt cọc" VerticalAlignment="Center" Foreground="#334155" />
                <TextBlock x:Name="TxtDatCoc" Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" />
                <Border Grid.Row="6" Grid.ColumnSpan="2" Background="#CBD5E1" />
                <TextBlock Grid.Row="7" Text="Cần thanh toán ngay" VerticalAlignment="Center" FontSize="17" FontWeight="Bold" Foreground="#0F172A" />
                <TextBlock x:Name="TxtCanThanhToan" Grid.Row="7" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="#DC2626" />
                <TextBlock Grid.Row="8" Grid.ColumnSpan="2" Margin="0,14,0,0" TextWrapping="Wrap" Foreground="#64748B"
                           Text="Dịch vụ đã có tại check-in được thanh toán trong lần này. Dịch vụ thêm sau khi nhận phòng sẽ thanh toán khi trả phòng." />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource ActionButton}" Background="#16A34A" BorderBrush="#15803D" Click="BtnThanhToan_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="CashCheck" Width="17" Height="17" Margin="0,0,7,0" />
                    <TextBlock Text="Xác nhận đã thanh toán" />
                </StackPanel>
            </Button>
            <Button Margin="10,0,0,0" Style="{StaticResource ActionButton}" Background="#64748B" BorderBrush="#475569" Click="BtnHuy_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,7,0" />
                    <TextBlock Text="Hủy" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
