<Window x:Class="QLKS_AnPhu.View.PhongChiTietWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Thông tin chi tiết"
        Width="1280"
        Height="760"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        Background="#F4F8FB"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <DropShadowEffect x:Key="PanelShadow" BlurRadius="8" Direction="270" ShadowDepth="2" Opacity="0.20" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#B9C6D8" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InfoBoxStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D7DEE8" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="Padding" Value="16,12" />
        </Style>

        <Style x:Key="SidebarInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#94A3B8" />
            <Setter Property="BorderThickness" Value="1.2" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>

        <Style x:Key="SidebarLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,8,0,4" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Style>
                <Style TargetType="iconPacks:PackIconMaterial">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Style>
            </Style.Resources>
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ButtonContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#E5E7EB" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#B6C2D1" />
                                <Setter Property="Foreground" Value="#475569" />
                                <Setter TargetName="ButtonContent" Property="TextElement.Foreground" Value="#475569" />
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BlueActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#0EA5E9" />
            <Setter Property="BorderBrush" Value="#0284C7" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="PinkActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#BE185D" />
            <Setter Property="BorderBrush" Value="#9D174D" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="GreenActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#16A34A" />
            <Setter Property="BorderBrush" Value="#15803D" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="OrangeActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#D97706" />
            <Setter Property="BorderBrush" Value="#B45309" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="GrayActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#4B5563" />
            <Setter Property="BorderBrush" Value="#374151" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Resources>

    <Grid Margin="20,14,20,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="96" />
            <RowDefinition Height="*" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="48" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TxtTieuDe"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#111827"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="TxtSoPhongHeader"
                       Grid.Column="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#17445E" />
            <iconPacks:PackIconMaterial Grid.Column="2"
                                        Kind="ClockOutline"
                                        Width="30"
                                        Height="30"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Foreground="#607284" />
        </Grid>

        <Grid Grid.Row="1" Margin="310,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource InfoBoxStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock Text="Ngày nhận phòng" FontSize="14" Foreground="#0F172A" />
                        <iconPacks:PackIconMaterial Kind="Calendar" Width="18" Height="18" Margin="4,0,0,0" Foreground="#5D99A5" />
                    </DockPanel>
                    <TextBox x:Name="TxtNgayNhan"
                             Grid.Row="1"
                             Height="34"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             FontSize="15"
                             IsReadOnly="True" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource InfoBoxStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock Text="Thời gian lưu trú" FontSize="14" Foreground="#0F172A" />
                        <iconPacks:PackIconMaterial Kind="Clock" Width="18" Height="18" Margin="4,0,0,0" Foreground="#5D99A5" />
                    </DockPanel>
                    <TextBlock x:Name="TxtThoiGianLuuTru"
                               Grid.Row="1"
                               Text="0 ngày"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="20"
                               FontWeight="Bold" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource InfoBoxStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock Text="Số lượng khách" FontSize="14" Foreground="#0F172A" />
                        <iconPacks:PackIconMaterial Kind="AccountGroup" Width="22" Height="22" Margin="4,0,0,0" Foreground="#5D99A5" />
                    </DockPanel>
                    <TextBlock x:Name="TxtSoLuongKhachHeader"
                               Grid.Row="1"
                               Text="--"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="20"
                               FontWeight="Bold" />
                </Grid>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource InfoBoxStyle}" BorderThickness="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <TextBlock Text="Trạng thái phòng" FontSize="14" Foreground="#0F172A" />
                        <iconPacks:PackIconMaterial Kind="Bed" Width="22" Height="22" Margin="4,0,0,0" Foreground="#607284" />
                    </DockPanel>
                    <TextBlock x:Name="TxtTrangThaiPhong"
                               Grid.Row="1"
                               Text="--"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.28*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="168" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="158" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="158" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#214B6A" CornerRadius="6" Padding="16,14" BorderBrush="#16344C" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="32" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="32" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Thông tin Khách hàng" Foreground="White" FontSize="16" FontWeight="Bold" />
                        <TextBlock Grid.Row="1" Text="Họ tên" Style="{StaticResource SidebarLabelStyle}" Margin="0,4,0,4" />
                        <TextBox x:Name="TxtHoTen" Grid.Row="2" Style="{StaticResource SidebarInputStyle}" />
                        <TextBlock Grid.Row="3" Text="SDT" Style="{StaticResource SidebarLabelStyle}" Margin="0,4,0,4" />
                        <TextBox x:Name="TxtSDT" Grid.Row="4" Style="{StaticResource SidebarInputStyle}" />
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#5B5044" CornerRadius="6" Padding="16,14" BorderBrush="#43382E" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="32" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="32" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Thông tin Đặt phòng" Foreground="White" FontSize="16" FontWeight="Bold" />
                        <TextBlock Grid.Row="1" Text="Ngày nhận phòng" Style="{StaticResource SidebarLabelStyle}" Margin="0,4,0,4" />
                        <TextBox x:Name="TxtNgayNhanSidebar" Grid.Row="2" Style="{StaticResource SidebarInputStyle}" />
                        <TextBlock Grid.Row="3" Text="Ngày trả phòng" Style="{StaticResource SidebarLabelStyle}" Margin="0,4,0,4" />
                        <TextBox x:Name="TxtNgayTra" Grid.Row="4" Style="{StaticResource SidebarInputStyle}" />
                    </Grid>
                </Border>

                <Border Grid.Row="4" Background="#214B6A" CornerRadius="6" Padding="16,14" BorderBrush="#16344C" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24" />
                            <RowDefinition Height="30" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="32" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Chi tiết Phòng" Foreground="White" FontSize="16" FontWeight="Bold" />
                        <Grid Grid.Row="1">
                            <TextBlock Text="Số lượng khách" VerticalAlignment="Center" Foreground="White" FontSize="13" />
                            <TextBlock x:Name="TxtSoLuongKhach" Text="--" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="White" FontSize="13" FontWeight="SemiBold" />
                        </Grid>
                        <TextBlock Grid.Row="2" Text="Loại phòng" Style="{StaticResource SidebarLabelStyle}" Margin="0,4,0,4" />
                        <TextBox x:Name="TxtLoaiPhong" Grid.Row="3" Style="{StaticResource SidebarInputStyle}" />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="44" />
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="DgDichVu"
                              Grid.Row="0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              RowHeight="32"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              AlternatingRowBackground="#F3F4F6"
                              BorderBrush="#94A3B8"
                              BorderThickness="1"
                              FontSize="13"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Height" Value="30" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="#334155" />
                                <Setter Property="Background" Value="#EEF2F7" />
                                <Setter Property="BorderBrush" Value="#CBD5E1" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dịch vụ" Binding="{Binding Ten}" Width="2*" MinWidth="150" />
                            <DataGridTextColumn Header="Số lượng" Binding="{Binding SoLuong}" Width="78" />
                            <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia, StringFormat={}{0:N0}}" Width="96" />
                            <DataGridTextColumn Header="Thành tiền" Binding="{Binding ThanhTien, StringFormat={}{0:N0}}" Width="108" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="108" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CboDichVuThem" Grid.Column="0" Height="30" DisplayMemberPath="Ten" />
                        <Grid Grid.Column="1" Margin="8,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnGiamSoLuongDichVu"
                                    Grid.Column="0"
                                    Content="-"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Foreground="#111827"
                                    Background="#F8FAFC"
                                    BorderBrush="#CBD5E1"
                                    Click="BtnGiamSoLuongDichVu_Click" />
                            <TextBox x:Name="TxtSoLuongDichVu"
                                     Grid.Column="1"
                                     Text="1"
                                     Height="30"
                                     Margin="4,0"
                                     Padding="0"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     FontWeight="SemiBold"
                                     Foreground="#111827"
                                     Background="White"
                                     BorderBrush="#94A3B8"
                                     PreviewTextInput="TxtSoLuongDichVu_PreviewTextInput"
                                     LostFocus="TxtSoLuongDichVu_LostFocus" />
                            <Button x:Name="BtnTangSoLuongDichVu"
                                    Grid.Column="2"
                                    Content="+"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Foreground="#111827"
                                    Background="#F8FAFC"
                                    BorderBrush="#CBD5E1"
                                    Click="BtnTangSoLuongDichVu_Click" />
                        </Grid>
                        <Button Grid.Column="2" Margin="8,0,0,0" Background="#16A34A" BorderBrush="#15803D" Foreground="White" Click="BtnThemDichVu_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="PlusCircle" Width="15" Height="15" Margin="0,0,5,0" />
                                <TextBlock Text="Thêm" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3" Margin="8,0,0,0" Background="#DC2626" BorderBrush="#B91C1C" Foreground="White" Click="BtnXoaDichVu_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="TrashCan" Width="15" Height="15" Margin="0,0,5,0" />
                                <TextBlock Text="Xóa" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource PanelBorderStyle}" Padding="28,24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="42" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Hóa đơn thanh toán" FontSize="22" FontWeight="Bold" Foreground="#111827" TextWrapping="Wrap" />
                        <TextBlock x:Name="TxtSoTienBanDau" Margin="0,16,0,0" FontSize="15" FontWeight="Bold" Foreground="#164763" TextWrapping="Wrap" />

                        <DataGrid x:Name="DgBangThanhToan"
                                  Margin="0,16,0,0"
                                  Height="186"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  RowHeight="30"
                                  GridLinesVisibility="All"
                                  BorderBrush="#CBD5E1"
                                  BorderThickness="1"
                                  FontSize="14">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Height" Value="30" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Foreground" Value="#334155" />
                                    <Setter Property="Background" Value="#EEF2F7" />
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Khoản mục" Binding="{Binding KhoanMuc}" Width="*" />
                                <DataGridTextColumn Header="Số tiền" Binding="{Binding SoTienHienThi}" Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Cần thanh toán thêm:" Margin="0,18,0,0" FontSize="16" FontWeight="Bold" />
                        <TextBlock x:Name="TxtKhaDung" Margin="0,10,0,0" HorizontalAlignment="Right" FontSize="24" FontWeight="Bold" Foreground="#DC2626" />
                    </StackPanel>

                    <Button Grid.Row="1" HorizontalAlignment="Right" Width="126" Background="White" BorderBrush="#D0D5DD" Foreground="#111827" Click="BtnInHoaDon_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Printer" Width="15" Height="15" Margin="0,0,6,0" Foreground="#111827" />
                            <TextBlock Text="In hóa đơn" Foreground="#111827" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button x:Name="BtnNhanPhong" Width="118" Style="{StaticResource BlueActionButtonStyle}" Click="BtnNhanPhong_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Login" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Nhận phòng" />
                    </StackPanel>
                </Button>
                <Button x:Name="BtnHuyDat" Width="104" Style="{StaticResource PinkActionButtonStyle}" Margin="10,0,0,0" Click="BtnHuyDat_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="CloseCircle" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Hủy đặt" />
                    </StackPanel>
                </Button>
                <Button x:Name="BtnTraPhong" Width="112" Style="{StaticResource GreenActionButtonStyle}" Margin="10,0,0,0" Click="BtnTraPhong_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Logout" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Trả phòng" />
                    </StackPanel>
                </Button>
                <Button x:Name="BtnGiaHanPhong" Width="116" Style="{StaticResource BlueActionButtonStyle}" Margin="10,0,0,0" Click="BtnGiaHanPhong_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="CalendarPlus" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Gia hạn phòng" />
                    </StackPanel>
                </Button>
                <Button x:Name="BtnDoiPhong" Width="108" Style="{StaticResource BlueActionButtonStyle}" Margin="10,0,0,0" Click="BtnDoiPhong_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="SwapHorizontal" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Đổi phòng" />
                    </StackPanel>
                </Button>
                <Button x:Name="BtnDonDep" Width="138" Style="{StaticResource OrangeActionButtonStyle}" Margin="10,0,0,0" Click="BtnDonDep_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Broom" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Dọn dẹp xong" />
                    </StackPanel>
                </Button>
                <Button x:Name="BtnThanhToan" Width="124" Style="{StaticResource BlueActionButtonStyle}" Margin="10,0,0,0" Click="BtnThanhToan_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="CashRegister" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Thanh toán" />
                    </StackPanel>
                </Button>
                <Button x:Name="BtnLuu" Width="86" Style="{StaticResource GreenActionButtonStyle}" Margin="10,0,0,0" Click="BtnLuu_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="16" Height="16" Margin="0,0,6,0" />
                        <TextBlock Text="Lưu" />
                    </StackPanel>
                </Button>
            </WrapPanel>

            <Button Style="{StaticResource GrayActionButtonStyle}"
                    Width="94"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="BtnThoat_Click">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="ExitToApp" Width="16" Height="16" Margin="0,0,6,0" />
                    <TextBlock Text="Thoát" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
