<UserControl x:Class="QLKS_AnPhu.View.PhieuThue"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1120"
             Background="#F7F8FA"
             Language="vi-VN"
             TextElement.FontFamily="Segoe UI"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <DropShadowEffect x:Key="GlassShadow" BlurRadius="22" ShadowDepth="5" Opacity="0.14" Color="#0F172A" />
        <DropShadowEffect x:Key="SoftButtonShadow" BlurRadius="12" ShadowDepth="2" Opacity="0.16" Color="#0F172A" />

        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Style>
                <Style TargetType="iconPacks:PackIconMaterial">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Style>
            </Style.Resources>
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect" Value="{StaticResource SoftButtonShadow}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="-1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Background" Value="#F8FAFC" />
        </Style>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FBFF" />
            <Setter Property="BorderBrush" Value="#D7E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect" Value="{StaticResource GlassShadow}" />
        </Style>

        <Style x:Key="FilterInputStyle" TargetType="Control" BasedOn="{StaticResource InputStyle}">
            <Setter Property="Height" Value="36" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderBrush" Value="#D8E2EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#F9FBFD" />
        </Style>

        <Style x:Key="TableCellTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="#243447" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ActionMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#EEF5FA" />
            <Setter Property="BorderBrush" Value="#D5E2ED" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DFF4F5" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9CD8DE" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#CDECEF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18,12,18,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#0F766E" BorderThickness="3,0,0,0" Padding="16,2,0,0" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="TÌM KIẾM PHIẾU THUÊ"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#0F172A" />
                <TextBlock Text="Tìm kiếm và lọc danh sách phiếu thuê theo các tiêu chí"
                           Margin="0,10,0,0"
                           FontSize="13"
                           Foreground="#64748B" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource PanelStyle}"
                Background="#DDF8FBFF"
                Padding="14,12">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
            <Grid MinWidth="1080">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="136" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="136" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="122" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="122" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="78" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Loại" FontSize="11" Foreground="#0F172A" />
                    <ComboBox x:Name="CboLoaiPhong" Margin="0,4,0,0" Style="{StaticResource FilterInputStyle}" SelectionChanged="BoLoc_Changed" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Trạng thái" FontSize="11" Foreground="#0F172A" />
                    <ComboBox x:Name="CboTrangThai" Margin="0,4,0,0" Style="{StaticResource FilterInputStyle}" SelectionChanged="BoLoc_Changed">
                        <ComboBoxItem Content="Tất cả" IsSelected="True" />
                        <ComboBoxItem Content="Đã đặt" />
                        <ComboBoxItem Content="Đang thuê" />
                        <ComboBoxItem Content="Đã trả phòng" />
                        <ComboBoxItem Content="Đã hủy" />
                    </ComboBox>
                </StackPanel>

                <TextBox x:Name="TxtTimKiem"
                         Grid.Column="4"
                         Margin="0,18,0,0"
                         Height="36"
                         Padding="34,0,10,0"
                         VerticalContentAlignment="Center"
                         FontSize="12"
                         Background="#F9FBFD"
                         BorderBrush="#D8E2EC"
                         TextChanged="TxtTimKiem_TextChanged"
                         ToolTip="Nhập từ khóa để tìm kiếm..." />

                <iconPacks:PackIconMaterial Grid.Column="4"
                                            Margin="11,18,0,0"
                                            Kind="Magnify"
                                            Width="14"
                                            Height="14"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Foreground="#64748B"
                                            IsHitTestVisible="False" />

                <DatePicker x:Name="DpTuNgay"
                            Grid.Column="6"
                            Margin="0,18,0,0"
                            Style="{StaticResource FilterInputStyle}"
                            SelectedDateChanged="BoLoc_Changed" />
                <DatePicker x:Name="DpDenNgay"
                            Grid.Column="8"
                            Margin="0,18,0,0"
                            Style="{StaticResource FilterInputStyle}"
                            SelectedDateChanged="BoLoc_Changed" />

                <Button Grid.Column="10"
                        Margin="0,18,0,0"
                        Style="{StaticResource ToolButtonStyle}"
                        Background="#0F8C86"
                        BorderBrush="#0B7D78"
                        Foreground="White"
                        Click="BtnTimKiem_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Height="14" Margin="0,0,6,0" />
                        <TextBlock Text="Tìm" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="12"
                        Margin="0,18,0,0"
                        Style="{StaticResource ToolButtonStyle}"
                        Background="#527A9A"
                        BorderBrush="#456A88"
                        Foreground="White"
                        Click="BtnLamMoi_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,6,0" />
                        <TextBlock Text="Đặt lại" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="14"
                        Margin="0,18,0,0"
                        Style="{StaticResource ToolButtonStyle}"
                        Background="#0B2F8A"
                        BorderBrush="#0B2F8A"
                        Foreground="White"
                        Click="BtnDatPhongMoi_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" Margin="0,0,5,0" />
                        <TextBlock Text="Đặt" />
                    </StackPanel>
                </Button>
            </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="30" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="14,0">
                    <TextBlock Text="DANH SÁCH PHIẾU THUÊ"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBlock x:Name="TxtTongBanGhi"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="#64748B" />
                </Grid>

                <DataGrid x:Name="DgPhieuThue"
                          Grid.Row="1"
                          Margin="14,0,14,0"
                          Background="Transparent"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeight="34"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          AlternationCount="2"
                          AlternatingRowBackground="#F3F7FA"
                          MouseDoubleClick="DgPhieuThue_MouseDoubleClick">
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="8,0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="#111827" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Height" Value="36" />
                            <Setter Property="Padding" Value="8,0" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Background" Value="#E6EEF6" />
                            <Setter Property="Foreground" Value="#243447" />
                            <Setter Property="BorderBrush" Value="#D4DEE8" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#FBFDFF" />
                            <Setter Property="Foreground" Value="#334155" />
                            <Setter Property="SnapsToDevicePixels" Value="True" />
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F1F6FA" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E6F4F5" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#D8EEF1" />
                                    <Setter Property="Foreground" Value="#111827" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding STT}" Width="46" ElementStyle="{StaticResource TableCellTextStyle}" />
                        <DataGridTextColumn Header="Mã phiếu" Binding="{Binding MaPhieuThue}" Width="96" ElementStyle="{StaticResource TableCellTextStyle}" />
                        <DataGridTextColumn Header="Khách/đoàn đặt" Binding="{Binding TenKhachHang}" Width="2*" MinWidth="190" ElementStyle="{StaticResource TableCellTextStyle}" />
                        <DataGridTemplateColumn Header="Số điện thoại" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="Phone" Width="13" Height="13" Margin="0,0,6,0" Foreground="#6B7D8F" />
                                        <TextBlock Text="{Binding SoDienThoai}" Style="{StaticResource TableCellTextStyle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Danh sách phòng" Width="190">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="KeyVariant" Width="13" Height="13" Margin="0,0,6,0" Foreground="#6B7D8F" />
                                        <TextBlock Text="{Binding TenPhong}" Style="{StaticResource TableCellTextStyle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Loại phòng" Binding="{Binding LoaiPhong}" Width="160" ElementStyle="{StaticResource TableCellTextStyle}" />
                        <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="150" ElementStyle="{StaticResource TableCellTextStyle}" />
                        <DataGridTemplateColumn Header="Thao tác" Width="82">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ActionMenuButtonStyle}" Click="BtnThaoTac_Click" ToolTip="Thao tác phiếu thuê">
                                        <iconPacks:PackIconMaterial Kind="DotsVertical" Width="16" Height="16" Foreground="#31465A" />
                                        <Button.ContextMenu>
                                            <ContextMenu Background="#EEF8FB" BorderBrush="#C9D8E4" BorderThickness="1" HasDropShadow="True">
                                                <MenuItem Header="Xem chi tiết" Click="MenuChiTiet_Click">
                                                    <MenuItem.Icon>
                                                        <iconPacks:PackIconMaterial Kind="Eye" Width="14" Height="14" Foreground="#0F766E" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Sửa" Click="MenuSua_Click">
                                                    <MenuItem.Icon>
                                                        <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14" Foreground="#2563EB" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator />
                                                <MenuItem Header="Xóa" Click="MenuXoa_Click" Foreground="#B91C1C">
                                                    <MenuItem.Icon>
                                                        <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" Foreground="#B91C1C" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="14,0" Background="#EDF5FA">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                        <TextBlock Text="Hiển thị 10 bản ghi trên trang"
                                   VerticalAlignment="Center"
                                   Foreground="#64748B"
                                   FontSize="12" />
                        <Border Width="1" Height="14" Background="#CAD8E4" Margin="14,0" />
                        <TextBlock Text="Trang"
                                   VerticalAlignment="Center"
                                   Foreground="#64748B"
                                   FontSize="12" />
                        <Button Width="24" Height="22" Margin="8,0,4,0" Padding="0" Background="Transparent" BorderThickness="0" Foreground="#334155" Content="&lt;" />
                        <TextBlock Text="1" VerticalAlignment="Center" Foreground="#0F172A" FontWeight="SemiBold" />
                        <Button Width="24" Height="22" Margin="4,0,0,0" Padding="0" Background="Transparent" BorderThickness="0" Foreground="#334155" Content="&gt;" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Width="118" Style="{StaticResource ToolButtonStyle}" Background="#F8FDFF" BorderBrush="#D8E2EC" Foreground="#0F172A" Click="BtnLamMoi_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,6,0" />
                    <TextBlock Text="Làm mới" />
                </StackPanel>
            </Button>
            <Button x:Name="BtnXuatExcel" Width="126" Margin="10,0,0,0" Style="{StaticResource ToolButtonStyle}" Background="#F8FDFF" BorderBrush="#D8E2EC" Foreground="#0F172A" Click="BtnXuatExcel_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="MicrosoftExcel" Width="14" Height="14" Margin="0,0,6,0" />
                    <TextBlock Text="Xuất Excel" />
                </StackPanel>
            </Button>
            <Button x:Name="BtnInDanhSach" Width="138" Margin="10,0,0,0" Style="{StaticResource ToolButtonStyle}" Background="#F8FDFF" BorderBrush="#D8E2EC" Foreground="#0F172A" Click="BtnInDanhSach_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Printer" Width="14" Height="14" Margin="0,0,6,0" />
                    <TextBlock Text="In danh sách" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
