<UserControl x:Class="QLKS_AnPhu.View.PhieuThue"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1120"
             Background="#F7F8FA"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Style>
                <Style TargetType="iconPacks:PackIconMaterial">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Style>
            </Style.Resources>
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAFAFA" />
            <Setter Property="BorderBrush" Value="#D8DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18,12,18,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="62" />
            <RowDefinition Height="*" />
            <RowDefinition Height="44" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#0F766E" BorderThickness="3,0,0,0" Padding="16,2,0,0" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="TÌM KIẾM PHIẾU THUÊ"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#0F172A" />
                <TextBlock Text="Tìm kiếm và lọc danh sách phiếu thuê theo các tiêu chí"
                           Margin="0,10,0,0"
                           FontSize="13"
                           Foreground="#64748B" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource PanelStyle}">
            <Grid Margin="12,9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="116" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="116" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="122" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="122" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="78" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Loại" FontSize="11" Foreground="#0F172A" />
                    <ComboBox x:Name="CboLoaiPhong" Margin="0,4,0,0" Style="{StaticResource InputStyle}" SelectionChanged="BoLoc_Changed" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Trạng" FontSize="11" Foreground="#0F172A" />
                    <ComboBox x:Name="CboTrangThai" Margin="0,4,0,0" Style="{StaticResource InputStyle}" SelectionChanged="BoLoc_Changed">
                        <ComboBoxItem Content="Tất cả" IsSelected="True" />
                        <ComboBoxItem Content="Đã đặt" />
                        <ComboBoxItem Content="Đang thuê" />
                        <ComboBoxItem Content="Đã trả phòng" />
                        <ComboBoxItem Content="Đã hủy" />
                    </ComboBox>
                </StackPanel>

                <TextBox x:Name="TxtTimKiem"
                         Grid.Column="4"
                         Margin="0,18,0,0"
                         Height="32"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         FontSize="12"
                         TextChanged="TxtTimKiem_TextChanged"
                         ToolTip="Nhập từ khóa để tìm kiếm..." />

                <DatePicker x:Name="DpTuNgay"
                            Grid.Column="6"
                            Margin="0,18,0,0"
                            Style="{StaticResource InputStyle}"
                            SelectedDateChanged="BoLoc_Changed" />
                <DatePicker x:Name="DpDenNgay"
                            Grid.Column="8"
                            Margin="0,18,0,0"
                            Style="{StaticResource InputStyle}"
                            SelectedDateChanged="BoLoc_Changed" />

                <Button Grid.Column="10"
                        Margin="0,18,0,0"
                        Style="{StaticResource ToolButtonStyle}"
                        Background="#0F766E"
                        BorderBrush="#0F766E"
                        Foreground="White"
                        Click="BtnTimKiem_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Height="14" Margin="0,0,6,0" />
                        <TextBlock Text="Tìm" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="12"
                        Margin="0,18,0,0"
                        Style="{StaticResource ToolButtonStyle}"
                        Background="#1F2937"
                        BorderBrush="#1F2937"
                        Foreground="White"
                        Click="BtnLamMoi_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,6,0" />
                        <TextBlock Text="Đặt lại" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="14"
                        Margin="0,18,0,0"
                        Style="{StaticResource ToolButtonStyle}"
                        Background="#0B2F8A"
                        BorderBrush="#0B2F8A"
                        Foreground="White"
                        Click="BtnDatPhongMoi_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" Margin="0,0,5,0" />
                        <TextBlock Text="Đặt" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="30" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="14,0">
                    <TextBlock Text="DANH SÁCH PHIẾU THUÊ"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#0F172A" />
                    <TextBlock x:Name="TxtTongBanGhi"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="#64748B" />
                </Grid>

                <DataGrid x:Name="DgPhieuThue"
                          Grid.Row="1"
                          Margin="14,0,14,0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeight="30"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          AlternationCount="2"
                          AlternatingRowBackground="#F8FAFC"
                          MouseDoubleClick="DgPhieuThue_MouseDoubleClick">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Height" Value="32" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Background" Value="#EEF2F7" />
                            <Setter Property="Foreground" Value="#334155" />
                            <Setter Property="BorderBrush" Value="#CBD5E1" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="Foreground" Value="#334155" />
                            <Setter Property="SnapsToDevicePixels" Value="True" />
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F8FAFC" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EEF4FF" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE" />
                                    <Setter Property="Foreground" Value="#111827" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding STT}" Width="46" />
                        <DataGridTextColumn Header="Mã phiếu" Binding="{Binding MaPhieuThue}" Width="84" />
                        <DataGridTextColumn Header="Khách/đoàn đặt" Binding="{Binding TenKhachHang}" Width="2*" MinWidth="180" />
                        <DataGridTextColumn Header="Số điện thoại" Binding="{Binding SoDienThoai}" Width="150" />
                        <DataGridTextColumn Header="Danh sách phòng" Binding="{Binding TenPhong}" Width="180" />
                        <DataGridTextColumn Header="Loại phòng" Binding="{Binding LoaiPhong}" Width="160" />
                        <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="150" />
                        <DataGridTemplateColumn Header="Thao tác" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="28"
                                            Height="24"
                                            Padding="0"
                                            Background="#E2E8F0"
                                            BorderBrush="#CBD5E1"
                                            Click="BtnMoChiTiet_Click"
                                            ToolTip="Xem chi tiết phiếu thuê">
                                        <TextBlock Text="⋮"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="#334155"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   LineHeight="16" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="14,0" Background="#F8FAFC">
                    <TextBlock Text="Hiển thị 10 bản ghi trên trang"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#64748B"
                               FontSize="12" />
                    <TextBlock Text="Trang  &lt;  1  &gt;"
                               Margin="0,0,8,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="#64748B"
                               FontSize="12" />
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Width="110" Style="{StaticResource ToolButtonStyle}" Background="White" BorderBrush="#CBD5E1" Foreground="#0F172A" Click="BtnLamMoi_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,6,0" />
                    <TextBlock Text="Làm mới" />
                </StackPanel>
            </Button>
            <Button Width="118" Margin="10,0,0,0" Style="{StaticResource ToolButtonStyle}" Background="White" BorderBrush="#CBD5E1" Foreground="#0F172A">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="MicrosoftExcel" Width="14" Height="14" Margin="0,0,6,0" />
                    <TextBlock Text="Xuất Excel" />
                </StackPanel>
            </Button>
            <Button Width="126" Margin="10,0,0,0" Style="{StaticResource ToolButtonStyle}" Background="White" BorderBrush="#CBD5E1" Foreground="#0F172A">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Printer" Width="14" Height="14" Margin="0,0,6,0" />
                    <TextBlock Text="In danh sách" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
