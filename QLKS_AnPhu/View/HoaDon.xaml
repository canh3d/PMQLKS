<UserControl x:Class="QLKS_AnPhu.View.HoaDon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1120"
             Background="#F7F8FA"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
       
    <UserControl.Resources>
               
        <SolidColorBrush x:Key="TextMainBrush" Color="#0F1F33" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#5D6B82" />
        <SolidColorBrush x:Key="DarkBlueBrush" Color="#003B73" />
        <SolidColorBrush x:Key="BlueBrush" Color="#0B55C7" />
        <SolidColorBrush x:Key="GreenBrush" Color="#078A55" />
        <SolidColorBrush x:Key="OrangeBrush" Color="#E57900" />
        <SolidColorBrush x:Key="RedBrush" Color="#D62828" />
        <SolidColorBrush x:Key="SlateBrush" Color="#334155" />

               
        <Style x:Key="InputBoxStyle" TargetType="Control">
                       
            <Setter Property="Height" Value="34" />
                       
            <Setter Property="FontSize" Value="14" />
                       
            <Setter Property="BorderBrush" Value="#B8C4D3" />
                       
            <Setter Property="BorderThickness" Value="1" />
                   
        </Style>

               
        <Style x:Key="ActionButtonStyle" TargetType="Button">
                       
            <Style.Resources>
                               
                <Style TargetType="TextBlock">
                                       
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                   
                </Style>
                               
                <Style TargetType="iconPacks:PackIconMaterial">
                                       
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                   
                </Style>
                           
            </Style.Resources>
                       
            <Setter Property="Height" Value="38" />
                       
            <Setter Property="Padding" Value="14,0" />
                       
            <Setter Property="FontSize" Value="14" />
                       
            <Setter Property="FontWeight" Value="SemiBold" />
                       
            <Setter Property="Cursor" Value="Hand" />
                       
            <Setter Property="BorderThickness" Value="1" />
                       
            <Setter Property="Template">
                               
                <Setter.Value>
                                       
                    <ControlTemplate TargetType="Button">
                                               
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                                                       
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                                                   
                        </Border>
                                               
                        <ControlTemplate.Triggers>
                                                       
                            <Trigger Property="IsMouseOver" Value="True">
                                                               
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                                                           
                            </Trigger>
                                                       
                            <Trigger Property="IsEnabled" Value="False">
                                                               
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Opacity" Value="1" />
                                                               
                                <Setter Property="Cursor" Value="Arrow" />
                                                           
                            </Trigger>
                                                   
                        </ControlTemplate.Triggers>
                                           
                    </ControlTemplate>
                                   
                </Setter.Value>
                           
            </Setter>
                   
        </Style>
           
    </UserControl.Resources>

       
    <Grid Margin="18,12,18,12">
               
        <Grid.RowDefinitions>
                       
            <RowDefinition Height="Auto" />
                       
            <RowDefinition Height="74" />
                       
            <RowDefinition Height="106" />
                       
            <RowDefinition Height="*" />
                       
            <RowDefinition Height="54" />
                   
        </Grid.RowDefinitions>

               
        <StackPanel Grid.Row="0" Visibility="Collapsed">
                       
            <TextBlock Text="Quản lý hóa đơn" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
                       
            <TextBlock Text="Theo dõi hóa đơn, thanh toán và doanh thu" Margin="0,14,0,0" FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                   
        </StackPanel>

               
        <Border Grid.Row="1"
                Background="#FAFAFA"
                BorderBrush="#D8DEE8"
                BorderThickness="1"
                CornerRadius="12">
                       
            <Grid Margin="18,13">
                               
                <Grid.ColumnDefinitions>
                                       
                    <ColumnDefinition Width="2.1*" />
                                       
                    <ColumnDefinition Width="18" />
                                       
                    <ColumnDefinition Width="62" />
                                       
                    <ColumnDefinition Width="116" />
                                       
                    <ColumnDefinition Width="18" />
                                       
                    <ColumnDefinition Width="52" />
                                       
                    <ColumnDefinition Width="128" />
                                       
                    <ColumnDefinition Width="18" />
                                       
                    <ColumnDefinition Width="58" />
                                       
                    <ColumnDefinition Width="128" />
                                       
                    <ColumnDefinition Width="14" />
                                       
                    <ColumnDefinition Width="92" />
                                       
                    <ColumnDefinition Width="10" />
                                       
                    <ColumnDefinition Width="104" />
                                   
                </Grid.ColumnDefinitions>

                               
                <TextBox x:Name="TxtTimKiem"
                         Grid.Column="0"
                         Height="34"
                         Padding="38,0,12,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         BorderBrush="#B8C4D3"
                         TextChanged="TxtTimKiem_TextChanged"
                         ToolTip="Nhập mã hóa đơn, tên khách hoặc phòng" />
                <iconPacks:PackIconMaterial Grid.Column="0"
                                            Kind="Magnify"
                                            Width="18"
                                            Height="18"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Margin="14,0,0,0"
                                            Foreground="#64748B"
                                            IsHitTestVisible="False" />

                                   
                    <TextBlock Grid.Column="2" Text="Trạng thái" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource TextMainBrush}" TextWrapping="Wrap" />
                                   
                    <ComboBox x:Name="CboTrangThai"
                          Grid.Column="3"
                          Style="{StaticResource InputBoxStyle}"
                          SelectionChanged="BoLoc_Changed">
                                           
                        <ComboBoxItem Content="Tất cả" IsSelected="True" />
                                           
                        <ComboBoxItem Content="Chưa thanh toán" />
                                           
                        <ComboBoxItem Content="Đã thanh toán" />
                                       
                    </ComboBox>

                                   
                    <TextBlock Grid.Column="5" Text="Từ ngày" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource TextMainBrush}" TextWrapping="Wrap" />
                                   
                    <DatePicker x:Name="DpTuNgay" Grid.Column="6" Style="{StaticResource InputBoxStyle}" SelectedDateChanged="BoLoc_Changed" />

                                   
                    <TextBlock Grid.Column="8" Text="Đến ngày" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource TextMainBrush}" TextWrapping="Wrap" />
                                   
                    <DatePicker x:Name="DpDenNgay" Grid.Column="9" Style="{StaticResource InputBoxStyle}" SelectedDateChanged="BoLoc_Changed" />

                                   
                    <Button Grid.Column="11"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="{StaticResource DarkBlueBrush}"
                        BorderBrush="{StaticResource DarkBlueBrush}"
                        Foreground="White"
                        Click="BtnLoc_Click">
                                           
                        <StackPanel Orientation="Horizontal">
                                                   
                            <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Height="14" Margin="0,0,6,0" />
                                                   
                            <TextBlock Text="Lọc" />
                                               
                        </StackPanel>
                                       
                    </Button>

                                   
                    <Button Grid.Column="13"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="White"
                        BorderBrush="#AAB4C2"
                        Foreground="{StaticResource TextMainBrush}"
                        Click="BtnLamMoi_Click">
                                           
                        <StackPanel Orientation="Horizontal">
                                                   
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,6,0" />
                                                   
                            <TextBlock Text="Làm mới" />
                                               
                        </StackPanel>
                                       
                    </Button>
                               
            </Grid>
                   
        </Border>

               
        <Grid Grid.Row="2" Margin="0,12,0,0">
                       
            <Grid.ColumnDefinitions>
                               
                <ColumnDefinition Width="*" />
                               
                <ColumnDefinition Width="12" />
                               
                <ColumnDefinition Width="*" />
                               
                <ColumnDefinition Width="12" />
                               
                <ColumnDefinition Width="*" />
                               
                <ColumnDefinition Width="12" />
                               
                <ColumnDefinition Width="*" />
                           
            </Grid.ColumnDefinitions>

                       
            <Border BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="16" Padding="14,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#EFF6FF" Offset="0" />
                        <GradientStop Color="#DBEAFE" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                               
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                                       
                    <Border Width="42" Height="42" Background="#DBEAFE" CornerRadius="13" VerticalAlignment="Center">
                                               
                        <iconPacks:PackIconMaterial Kind="ReceiptText" Width="24" Height="24" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                           
                    </Border>
                                       
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                               
                        <TextBlock Text="Tổng hóa đơn" FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                                               
                        <TextBlock x:Name="TxtTongHoaDon" Text="0" Margin="0,3,0,0" FontSize="23" FontWeight="Bold" Foreground="#1D4ED8" />
                        <TextBlock Text="+15% so với tháng trước" Margin="0,2,0,0" FontSize="9.5" FontWeight="SemiBold" Foreground="#2563EB" />
                                           
                    </StackPanel>
                                   
                </Grid>
                           
            </Border>

                       
            <Border Grid.Column="2" BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="16" Padding="14,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFBEB" Offset="0" />
                        <GradientStop Color="#FEF3C7" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                               
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                                       
                    <Border Width="42" Height="42" Background="#FDE68A" CornerRadius="13" VerticalAlignment="Center">
                                               
                        <iconPacks:PackIconMaterial Kind="ClockOutline" Width="24" Height="24" Foreground="#B45309" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                           
                    </Border>
                                       
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                               
                        <TextBlock Text="Chưa thanh toán" FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                                               
                        <TextBlock x:Name="TxtChuaThanhToan" Text="0" Margin="0,3,0,0" FontSize="23" FontWeight="Bold" Foreground="#B45309" />
                        <TextBlock Text="Cần xử lý trong ngày" Margin="0,2,0,0" FontSize="9.5" FontWeight="SemiBold" Foreground="#B45309" />
                                           
                    </StackPanel>
                                   
                </Grid>
                           
            </Border>

                       
            <Border Grid.Column="4" BorderBrush="#BBF7D0" BorderThickness="1" CornerRadius="16" Padding="14,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F0FDF4" Offset="0" />
                        <GradientStop Color="#DCFCE7" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                               
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                                       
                    <Border Width="42" Height="42" Background="#BBF7D0" CornerRadius="13" VerticalAlignment="Center">
                                               
                        <iconPacks:PackIconMaterial Kind="CheckCircleOutline" Width="24" Height="24" Foreground="#15803D" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                           
                    </Border>
                                       
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                               
                        <TextBlock Text="Đã thanh toán" FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                                               
                        <TextBlock x:Name="TxtDaThanhToan" Text="0" Margin="0,3,0,0" FontSize="23" FontWeight="Bold" Foreground="#15803D" />
                        <TextBlock Text="Tỷ lệ hoàn tất tốt" Margin="0,2,0,0" FontSize="9.5" FontWeight="SemiBold" Foreground="#15803D" />
                                           
                    </StackPanel>
                                   
                </Grid>
                           
            </Border>

                       
            <Border Grid.Column="6" BorderBrush="#E9D5FF" BorderThickness="1" CornerRadius="16" Padding="14,10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FAF5FF" Offset="0" />
                        <GradientStop Color="#F3E8FF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                               
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                                       
                    <Border Width="42" Height="42" Background="#E9D5FF" CornerRadius="13" VerticalAlignment="Center">
                                               
                        <iconPacks:PackIconMaterial Kind="CashMultiple" Width="24" Height="24" Foreground="#7E22CE" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                           
                    </Border>
                                       
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                               
                        <TextBlock Text="Doanh thu" FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                                               
                        <TextBlock x:Name="TxtDoanhThu" Text="0 VND" Margin="0,3,0,0" FontSize="19" FontWeight="Bold" Foreground="#7E22CE" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="Doanh thu đã thanh toán" Margin="0,2,0,0" FontSize="9.5" FontWeight="SemiBold" Foreground="#7E22CE" />
                                           
                    </StackPanel>
                                   
                </Grid>
                           
            </Border>
                   
        </Grid>

               
        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Background="#FAFAFA"
                BorderBrush="#D8DEE8"
                BorderThickness="1"
                CornerRadius="12">
                       
            <Grid>
                               
                <Grid.RowDefinitions>
                                       
                    <RowDefinition Height="40" />
                                       
                    <RowDefinition Height="42" />
                                       
                    <RowDefinition Height="*" />
                                       
                    <RowDefinition Height="32" />
                                   
                </Grid.RowDefinitions>

                               
                <Grid Grid.Row="0" Margin="12,0">
                                       
                    <TextBlock Text="DANH SÁCH HÓA ĐƠN" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextMainBrush}" />
                                       
                    <TextBlock x:Name="TxtTongSo" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" Foreground="#245BFF" />
                                   
                </Grid>

                <TabControl x:Name="TabLoaiHoaDon" Grid.Row="1" Margin="12,0,12,6" SelectionChanged="TabLoaiHoaDon_SelectionChanged">
                    <TabItem Header="Thanh toán lúc nhận phòng" Tag="CHECKIN" />
                    <TabItem Header="Thanh toán phát sinh thêm" Tag="PHATSINH" />
                </TabControl>
                               
                <DataGrid x:Name="DgHoaDon"
                          Grid.Row="2"
                          Margin="12,0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeight="32"
                          FontSize="12"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          AlternationCount="2"
                          AlternatingRowBackground="#F8FAFC"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          BorderBrush="#D8DEE8"
                          BorderThickness="0"
                          SelectionChanged="DgHoaDon_SelectionChanged"
                          MouseDoubleClick="DgHoaDon_MouseDoubleClick">
                                       
                    <DataGrid.ColumnHeaderStyle>
                                               
                        <Style TargetType="DataGridColumnHeader">
                                                       
                            <Setter Property="Height" Value="32" />
                                                       
                            <Setter Property="FontSize" Value="12" />
                                                       
                            <Setter Property="FontWeight" Value="SemiBold" />
                                                       
                            <Setter Property="Background" Value="#EEF2F7" />
                            <Setter Property="Foreground" Value="#334155" />
                                                       
                            <Setter Property="BorderBrush" Value="#CBD5E1" />
                                                       
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                                                   
                        </Style>
                                           
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="Foreground" Value="#334155" />
                            <Setter Property="SnapsToDevicePixels" Value="True" />
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F8FAFC" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EEF4FF" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE" />
                                    <Setter Property="Foreground" Value="#111827" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                                       
                    <DataGrid.Columns>
                                               
                        <DataGridTextColumn Header="Mã hóa đơn" Binding="{Binding MaHoaDon}" Width="150" />
                                               
                        <DataGridTextColumn Header="Phòng" Binding="{Binding SoPhong}" Width="130" />

                        <DataGridTextColumn Header="Tên khách hàng" Binding="{Binding TenKhachHang}" Width="190" />

                        <DataGridTextColumn Header="Ngày lập" Binding="{Binding NgayLapText}" Width="120" />

                        <DataGridTextColumn Header="Phụ phí" Binding="{Binding PhuPhiText}" Width="150" />

                        <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTienText}" Width="150" />

                        <DataGridTemplateColumn Header="Trạng thái" Width="170">
                                                       
                            <DataGridTemplateColumn.CellTemplate>
                                                               
                                <DataTemplate>
                                                                       
                                    <Border Background="{Binding TrangThaiBackground}" CornerRadius="10" Padding="10,3" HorizontalAlignment="Stretch">
                                                                               
                                        <TextBlock Text="{Binding TrangThai}" Foreground="{Binding TrangThaiForeground}" TextAlignment="Center" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                           
                                    </Border>
                                                                   
                                </DataTemplate>
                                                           
                            </DataGridTemplateColumn.CellTemplate>
                                                       
                        </DataGridTemplateColumn>
                                           
                    </DataGrid.Columns>
                                   
                </DataGrid>

                               
                <Grid Grid.Row="3" Margin="12,0" Background="#F8FAFC">
                                       
                    <TextBlock x:Name="TxtTrang" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextMainBrush}" FontSize="14" />
                                   
                </Grid>
                           
            </Grid>
                   
        </Border>

               
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
                       
            <Button x:Name="BtnChiTiet" Width="104" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource DarkBlueBrush}" BorderBrush="{StaticResource DarkBlueBrush}" Foreground="White" Click="BtnChiTiet_Click">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <iconPacks:PackIconMaterial Kind="Information" Width="14" Height="14" Margin="0,0,6,0" />
                                       
                    <TextBlock Text="Chi tiết" />
                                   
                </StackPanel>
                           
            </Button>
                       
            <Button x:Name="BtnThanhToan" Width="130" Margin="10,0,0,0" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource GreenBrush}" BorderBrush="{StaticResource GreenBrush}" Foreground="White" Click="BtnThanhToan_Click">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <iconPacks:PackIconMaterial Kind="CashCheck" Width="14" Height="14" Margin="0,0,6,0" />
                                       
                    <TextBlock Text="Thanh toán" />
                                   
                </StackPanel>
                           
            </Button>
                       
            <Button x:Name="BtnInHoaDon" Width="126" Margin="10,0,0,0" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource OrangeBrush}" BorderBrush="{StaticResource OrangeBrush}" Foreground="White" Click="BtnInHoaDon_Click">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <iconPacks:PackIconMaterial Kind="Printer" Width="14" Height="14" Margin="0,0,6,0" />
                                       
                    <TextBlock Text="In hóa đơn" />
                                   
                </StackPanel>
                           
            </Button>

            <Button x:Name="BtnTachBill" MinWidth="126" Margin="10,0,0,0" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource PurpleBrush}" BorderBrush="{StaticResource PurpleBrush}" Foreground="White" Click="BtnTachBill_Click">

                <StackPanel Orientation="Horizontal">

                    <iconPacks:PackIconMaterial Kind="CallSplit" Width="14" Height="14" Margin="0,0,6,0" />

                    <TextBlock Text="Tách bill" />

                </StackPanel>

            </Button>
                       
            <Button x:Name="BtnXoaHoaDon" Width="146" Margin="10,0,0,0" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource RedBrush}" BorderBrush="{StaticResource RedBrush}" Foreground="White" Click="BtnXoaHoaDon_Click">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" Margin="0,0,6,0" />
                                       
                    <TextBlock Text="Xóa hóa đơn" />
                                   
                </StackPanel>
                           
            </Button>
                       
            <Button Width="116" Margin="10,0,0,0" Style="{StaticResource ActionButtonStyle}" Background="White" BorderBrush="#AAB4C2" Foreground="{StaticResource TextMainBrush}" Click="BtnLamMoi_Click">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,6,0" />
                                       
                    <TextBlock Text="Làm mới" />
                                   
                </StackPanel>
                           
            </Button>
                   
        </StackPanel>

        <Border x:Name="LoadingOverlay"
                Grid.RowSpan="5"
                Background="#CCF8FAFC"
                CornerRadius="18"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="AN PHÚ HOTEL"
                           HorizontalAlignment="Center"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource DarkBlueBrush}" />
                <TextBlock Text="Đang tải dữ liệu hóa đơn..."
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextMutedBrush}" />
                <ProgressBar Width="260"
                             Height="6"
                             Margin="0,18,0,0"
                             IsIndeterminate="True"
                             Foreground="{StaticResource BlueBrush}" />
            </StackPanel>
        </Border>
           
    </Grid>
</UserControl>


