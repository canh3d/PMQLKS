<UserControl x:Class="QLKS_AnPhu.View.HoaDon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1120"
             Background="#F7F8FA"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
       
    <UserControl.Resources>
               
        <SolidColorBrush x:Key="TextMainBrush" Color="#0F1F33" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#5D6B82" />
        <SolidColorBrush x:Key="DarkBlueBrush" Color="#003B73" />
        <SolidColorBrush x:Key="BlueBrush" Color="#0B55C7" />
        <SolidColorBrush x:Key="GreenBrush" Color="#078A55" />
        <SolidColorBrush x:Key="OrangeBrush" Color="#E57900" />
        <SolidColorBrush x:Key="RedBrush" Color="#D62828" />
        <SolidColorBrush x:Key="SlateBrush" Color="#334155" />

               
        <Style x:Key="InputBoxStyle" TargetType="Control">
                       
            <Setter Property="Height" Value="34" />
                       
            <Setter Property="FontSize" Value="14" />
                       
            <Setter Property="BorderBrush" Value="#B8C4D3" />
                       
            <Setter Property="BorderThickness" Value="1" />
                   
        </Style>

               
        <Style x:Key="ActionButtonStyle" TargetType="Button">
                       
            <Style.Resources>
                               
                <Style TargetType="TextBlock">
                                       
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                   
                </Style>
                               
                <Style TargetType="iconPacks:PackIconMaterial">
                                       
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                   
                </Style>
                           
            </Style.Resources>
                       
            <Setter Property="Height" Value="38" />
                       
            <Setter Property="Padding" Value="14,0" />
                       
            <Setter Property="FontSize" Value="14" />
                       
            <Setter Property="FontWeight" Value="SemiBold" />
                       
            <Setter Property="Cursor" Value="Hand" />
                       
            <Setter Property="BorderThickness" Value="1" />
                       
            <Setter Property="Template">
                               
                <Setter.Value>
                                       
                    <ControlTemplate TargetType="Button">
                                               
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                                                       
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                                                   
                        </Border>
                                               
                        <ControlTemplate.Triggers>
                                                       
                            <Trigger Property="IsMouseOver" Value="True">
                                                               
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                                                           
                            </Trigger>
                                                       
                            <Trigger Property="IsEnabled" Value="False">
                                                               
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="Opacity" Value="1" />
                                                               
                                <Setter Property="Cursor" Value="Arrow" />
                                                           
                            </Trigger>
                                                   
                        </ControlTemplate.Triggers>
                                           
                    </ControlTemplate>
                                   
                </Setter.Value>
                           
            </Setter>
                   
        </Style>
           
    </UserControl.Resources>

       
    <Grid Margin="18,12,18,12">
               
        <Grid.RowDefinitions>
                       
            <RowDefinition Height="Auto" />
                       
            <RowDefinition Height="74" />
                       
            <RowDefinition Height="96" />
                       
            <RowDefinition Height="*" />
                       
            <RowDefinition Height="44" />
                   
        </Grid.RowDefinitions>

               
        <StackPanel Grid.Row="0" Visibility="Collapsed">
                       
            <TextBlock Text="Quản lý hóa đơn" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
                       
            <TextBlock Text="Theo dõi hóa đơn, thanh toán và doanh thu" Margin="0,14,0,0" FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                   
        </StackPanel>

               
        <Border Grid.Row="1"
                Background="#FAFAFA"
                BorderBrush="#D8DEE8"
                BorderThickness="1"
                CornerRadius="12">
                       
            <Grid Margin="18,13">
                               
                <Grid.ColumnDefinitions>
                                       
                    <ColumnDefinition Width="2.1*" />
                                       
                    <ColumnDefinition Width="18" />
                                       
                    <ColumnDefinition Width="62" />
                                       
                    <ColumnDefinition Width="116" />
                                       
                    <ColumnDefinition Width="18" />
                                       
                    <ColumnDefinition Width="52" />
                                       
                    <ColumnDefinition Width="128" />
                                       
                    <ColumnDefinition Width="18" />
                                       
                    <ColumnDefinition Width="58" />
                                       
                    <ColumnDefinition Width="128" />
                                       
                    <ColumnDefinition Width="14" />
                                       
                    <ColumnDefinition Width="92" />
                                       
                    <ColumnDefinition Width="10" />
                                       
                    <ColumnDefinition Width="104" />
                                   
                </Grid.ColumnDefinitions>

                               
                <TextBox x:Name="TxtTimKiem"
                         Grid.Column="0"
                         Height="34"
                         Padding="12,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         BorderBrush="#B8C4D3"
                         TextChanged="TxtTimKiem_TextChanged"
                         ToolTip="Nhập mã hóa đơn, tên khách hoặc phòng" />

                                   
                    <TextBlock Grid.Column="2" Text="Trạng thái" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource TextMainBrush}" TextWrapping="Wrap" />
                                   
                    <ComboBox x:Name="CboTrangThai"
                          Grid.Column="3"
                          Style="{StaticResource InputBoxStyle}"
                          SelectionChanged="BoLoc_Changed">
                                           
                        <ComboBoxItem Content="Tất cả" IsSelected="True" />
                                           
                        <ComboBoxItem Content="Chưa thanh toán" />
                                           
                        <ComboBoxItem Content="Đã thanh toán" />
                                       
                    </ComboBox>

                                   
                    <TextBlock Grid.Column="5" Text="Từ ngày" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource TextMainBrush}" TextWrapping="Wrap" />
                                   
                    <DatePicker x:Name="DpTuNgay" Grid.Column="6" Style="{StaticResource InputBoxStyle}" SelectedDateChanged="BoLoc_Changed" />

                                   
                    <TextBlock Grid.Column="8" Text="Đến ngày" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource TextMainBrush}" TextWrapping="Wrap" />
                                   
                    <DatePicker x:Name="DpDenNgay" Grid.Column="9" Style="{StaticResource InputBoxStyle}" SelectedDateChanged="BoLoc_Changed" />

                                   
                    <Button Grid.Column="11"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="{StaticResource DarkBlueBrush}"
                        BorderBrush="{StaticResource DarkBlueBrush}"
                        Foreground="White"
                        Click="BtnLoc_Click">
                                           
                        <StackPanel Orientation="Horizontal">
                                                   
                            <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Height="14" Margin="0,0,6,0" />
                                                   
                            <TextBlock Text="Lọc" />
                                               
                        </StackPanel>
                                       
                    </Button>

                                   
                    <Button Grid.Column="13"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="White"
                        BorderBrush="#AAB4C2"
                        Foreground="{StaticResource TextMainBrush}"
                        Click="BtnLamMoi_Click">
                                           
                        <StackPanel Orientation="Horizontal">
                                                   
                            <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,6,0" />
                                                   
                            <TextBlock Text="Làm mới" />
                                               
                        </StackPanel>
                                       
                    </Button>
                               
            </Grid>
                   
        </Border>

               
        <Grid Grid.Row="2" Margin="0,12,0,0">
                       
            <Grid.ColumnDefinitions>
                               
                <ColumnDefinition Width="*" />
                               
                <ColumnDefinition Width="12" />
                               
                <ColumnDefinition Width="*" />
                               
                <ColumnDefinition Width="12" />
                               
                <ColumnDefinition Width="*" />
                               
                <ColumnDefinition Width="12" />
                               
                <ColumnDefinition Width="*" />
                           
            </Grid.ColumnDefinitions>

                       
            <Border Background="#FAFAFA" BorderBrush="#D8DEE8" BorderThickness="1" CornerRadius="12" Padding="14">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <Border Width="46" Height="46" Background="#E0F2FE" CornerRadius="7">
                                               
                        <iconPacks:PackIconMaterial Kind="ReceiptText" Width="24" Height="24" Foreground="#075985" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                           
                    </Border>
                                       
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                               
                        <TextBlock Text="Tổng hóa đơn" FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                                               
                        <TextBlock x:Name="TxtTongHoaDon" Text="0" Margin="0,5,0,0" FontSize="24" FontWeight="Bold" Foreground="#075985" />
                                           
                    </StackPanel>
                                   
                </StackPanel>
                           
            </Border>

                       
            <Border Grid.Column="2" Background="#FAFAFA" BorderBrush="#D8DEE8" BorderThickness="1" CornerRadius="12" Padding="14">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <Border Width="46" Height="46" Background="#FEF3C7" CornerRadius="7">
                                               
                        <iconPacks:PackIconMaterial Kind="ClockOutline" Width="24" Height="24" Foreground="#B45309" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                           
                    </Border>
                                       
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                               
                        <TextBlock Text="Chưa thanh toán" FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                                               
                        <TextBlock x:Name="TxtChuaThanhToan" Text="0" Margin="0,5,0,0" FontSize="24" FontWeight="Bold" Foreground="#B45309" />
                                           
                    </StackPanel>
                                   
                </StackPanel>
                           
            </Border>

                       
            <Border Grid.Column="4" Background="#FAFAFA" BorderBrush="#D8DEE8" BorderThickness="1" CornerRadius="12" Padding="14">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <Border Width="46" Height="46" Background="#DCFCE7" CornerRadius="7">
                                               
                        <iconPacks:PackIconMaterial Kind="CheckCircleOutline" Width="24" Height="24" Foreground="#15803D" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                           
                    </Border>
                                       
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                               
                        <TextBlock Text="Đã thanh toán" FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                                               
                        <TextBlock x:Name="TxtDaThanhToan" Text="0" Margin="0,5,0,0" FontSize="24" FontWeight="Bold" Foreground="#15803D" />
                                           
                    </StackPanel>
                                   
                </StackPanel>
                           
            </Border>

                       
            <Border Grid.Column="6" Background="#FAFAFA" BorderBrush="#D8DEE8" BorderThickness="1" CornerRadius="12" Padding="14">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <Border Width="46" Height="46" Background="#F3E8FF" CornerRadius="7">
                                               
                        <iconPacks:PackIconMaterial Kind="CashMultiple" Width="24" Height="24" Foreground="#7E22CE" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                           
                    </Border>
                                       
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                               
                        <TextBlock Text="Doanh thu" FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                                               
                        <TextBlock x:Name="TxtDoanhThu" Text="0 VND" Margin="0,5,0,0" FontSize="24" FontWeight="Bold" Foreground="#7E22CE" />
                                           
                    </StackPanel>
                                   
                </StackPanel>
                           
            </Border>
                   
        </Grid>

               
        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Background="#FAFAFA"
                BorderBrush="#D8DEE8"
                BorderThickness="1"
                CornerRadius="12">
                       
            <Grid>
                               
                <Grid.RowDefinitions>
                                       
                    <RowDefinition Height="40" />
                                       
                    <RowDefinition Height="42" />
                                       
                    <RowDefinition Height="*" />
                                       
                    <RowDefinition Height="32" />
                                   
                </Grid.RowDefinitions>

                               
                <Grid Grid.Row="0" Margin="12,0">
                                       
                    <TextBlock Text="DANH SÁCH HÓA ĐƠN" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextMainBrush}" />
                                       
                    <TextBlock x:Name="TxtTongSo" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" Foreground="#245BFF" />
                                   
                </Grid>

                <TabControl x:Name="TabLoaiHoaDon" Grid.Row="1" Margin="12,0,12,6" SelectionChanged="TabLoaiHoaDon_SelectionChanged">
                    <TabItem Header="Thanh toán lúc nhận phòng" Tag="CHECKIN" />
                    <TabItem Header="Thanh toán phát sinh thêm" Tag="PHATSINH" />
                </TabControl>
                               
                <DataGrid x:Name="DgHoaDon"
                          Grid.Row="2"
                          Margin="12,0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeight="31"
                          FontSize="14"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          AlternationCount="2"
                          AlternatingRowBackground="#F8FAFC"
                          BorderBrush="#D8DEE8"
                          BorderThickness="0"
                          SelectionChanged="DgHoaDon_SelectionChanged"
                          MouseDoubleClick="DgHoaDon_MouseDoubleClick">
                                       
                    <DataGrid.ColumnHeaderStyle>
                                               
                        <Style TargetType="DataGridColumnHeader">
                                                       
                            <Setter Property="Height" Value="34" />
                                                       
                            <Setter Property="FontSize" Value="13" />
                                                       
                            <Setter Property="FontWeight" Value="SemiBold" />
                                                       
                            <Setter Property="Background" Value="#EEF2F7" />
                            <Setter Property="Foreground" Value="#334155" />
                                                       
                            <Setter Property="BorderBrush" Value="#CBD5E1" />
                                                       
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                                                   
                        </Style>
                                           
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White" />
                            <Setter Property="Foreground" Value="#334155" />
                            <Setter Property="SnapsToDevicePixels" Value="True" />
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#F8FAFC" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EEF4FF" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DBEAFE" />
                                    <Setter Property="Foreground" Value="#111827" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                                       
                    <DataGrid.Columns>
                                               
                        <DataGridTextColumn Header="Mã hóa đơn" Binding="{Binding MaHoaDon}" Width="112" />
                                               
                        <DataGridTextColumn Header="Mã phiếu thuê" Binding="{Binding MaPhieuThue}" Width="116" />
                                               
                        <DataGridTextColumn Header="Tên khách hàng" Binding="{Binding TenKhachHang}" Width="1.5*" MinWidth="150" />
                                               
                        <DataGridTextColumn Header="Số phòng" Binding="{Binding SoPhong}" Width="86" />
                                               
                        <DataGridTextColumn Header="Ngày nhận phòng" Binding="{Binding NgayNhanText}" Width="128" />
                                               
                        <DataGridTextColumn Header="Ngày trả phòng" Binding="{Binding NgayTraText}" Width="128" />
                                               
                        <DataGridTextColumn x:Name="ColTienPhong" Header="Tiền phòng lúc check-in" Binding="{Binding TienPhongText}" Width="148" />
                                               
                        <DataGridTextColumn Header="Tiền dịch vụ" Binding="{Binding TienDichVuText}" Width="104" />
                                               
                        <DataGridTextColumn Header="Phụ phí" Binding="{Binding PhuPhiText}" Width="92" />
                                               
                        <DataGridTextColumn Header="Giảm giá" Binding="{Binding GiamGiaText}" Width="92" />
                                               
                        <DataGridTextColumn Header="Thuế VAT" Binding="{Binding ThueVatText}" Width="92" />
                                               
                        <DataGridTextColumn Header="Tổng tiền" Binding="{Binding TongTienText}" Width="106" />
                                               
                        <DataGridTemplateColumn Header="Trạng thái" Width="132">
                                                       
                            <DataGridTemplateColumn.CellTemplate>
                                                               
                                <DataTemplate>
                                                                       
                                    <Border Background="{Binding TrangThaiBackground}" CornerRadius="3" Padding="8,2" HorizontalAlignment="Stretch">
                                                                               
                                        <TextBlock Text="{Binding TrangThai}" Foreground="{Binding TrangThaiForeground}" TextAlignment="Center" FontSize="13" FontWeight="SemiBold" />
                                                                           
                                    </Border>
                                                                   
                                </DataTemplate>
                                                           
                            </DataGridTemplateColumn.CellTemplate>
                                                   
                        </DataGridTemplateColumn>
                                               
                        <DataGridTextColumn Header="Ngày lập hóa đơn" Binding="{Binding NgayLapText}" Width="128" />
                                           
                    </DataGrid.Columns>
                                   
                </DataGrid>

                               
                <Grid Grid.Row="3" Margin="12,0" Background="#F8FAFC">
                                       
                    <TextBlock x:Name="TxtTrang" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource TextMainBrush}" FontSize="14" />
                                   
                </Grid>
                           
            </Grid>
                   
        </Border>

               
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
                       
            <Button x:Name="BtnChiTiet" Width="104" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource DarkBlueBrush}" BorderBrush="{StaticResource DarkBlueBrush}" Foreground="White" Click="BtnChiTiet_Click">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <iconPacks:PackIconMaterial Kind="Information" Width="14" Height="14" Margin="0,0,6,0" />
                                       
                    <TextBlock Text="Chi tiết" />
                                   
                </StackPanel>
                           
            </Button>
                       
            <Button x:Name="BtnThanhToan" Width="130" Margin="10,0,0,0" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource GreenBrush}" BorderBrush="{StaticResource GreenBrush}" Foreground="White" Click="BtnThanhToan_Click">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <iconPacks:PackIconMaterial Kind="CashCheck" Width="14" Height="14" Margin="0,0,6,0" />
                                       
                    <TextBlock Text="Thanh toán" />
                                   
                </StackPanel>
                           
            </Button>
                       
            <Button x:Name="BtnInHoaDon" Width="126" Margin="10,0,0,0" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource OrangeBrush}" BorderBrush="{StaticResource OrangeBrush}" Foreground="White" Click="BtnInHoaDon_Click">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <iconPacks:PackIconMaterial Kind="Printer" Width="14" Height="14" Margin="0,0,6,0" />
                                       
                    <TextBlock Text="In hóa đơn" />
                                   
                </StackPanel>
                           
            </Button>
                       
            <Button x:Name="BtnXoaHoaDon" Width="130" Margin="10,0,0,0" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource RedBrush}" BorderBrush="{StaticResource RedBrush}" Foreground="White" Click="BtnXoaHoaDon_Click">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" Margin="0,0,6,0" />
                                       
                    <TextBlock Text="Xóa hóa đơn" />
                                   
                </StackPanel>
                           
            </Button>
                       
            <Button Width="116" Margin="10,0,0,0" Style="{StaticResource ActionButtonStyle}" Background="White" BorderBrush="#AAB4C2" Foreground="{StaticResource TextMainBrush}" Click="BtnLamMoi_Click">
                               
                <StackPanel Orientation="Horizontal">
                                       
                    <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,6,0" />
                                       
                    <TextBlock Text="Làm mới" />
                                   
                </StackPanel>
                           
            </Button>
                   
        </StackPanel>
           
    </Grid>
</UserControl>

