<Window x:Class="QLKS_AnPhu.View.DoiPhongWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Đổi phòng" Width="780" Height="570"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner" Background="#F8FAFC">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Đổi phòng" FontSize="24" FontWeight="Bold" Foreground="#0F172A" />
            <TextBlock x:Name="TxtPhongHienTai" Margin="0,6,0,0" FontSize="15" Foreground="#475569" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,20,0,14" Padding="14" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Giờ trả dự kiến" VerticalAlignment="Center" Foreground="#334155" />
                <TextBlock x:Name="TxtNgayTra" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="Phòng trống" VerticalAlignment="Center" Foreground="#334155" />
                <TextBlock x:Name="TxtSoLuongPhong" Grid.Column="3" VerticalAlignment="Center" FontWeight="SemiBold" />
            </Grid>
        </Border>

        <DataGrid x:Name="DgPhong" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" SelectionMode="Single" RowHeight="34"
                  BorderBrush="#CBD5E1" BorderThickness="1" GridLinesVisibility="Horizontal">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Height" Value="36" />
                    <Setter Property="Background" Value="#E5ECF5" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Phòng" Binding="{Binding MaHienThi}" Width="120" />
                <DataGridTextColumn Header="Loại phòng" Binding="{Binding LoaiPhong}" Width="*" />
                <DataGridTextColumn Header="Tầng" Binding="{Binding Tang}" Width="90" />
                <DataGridTextColumn Header="Giá ngày" Binding="{Binding GiaNgay, StringFormat={}{0:N0} VND}" Width="160" />
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource ActionButton}" Background="#0284C7" BorderBrush="#0369A1" Click="BtnXacNhan_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="SwapHorizontal" Width="17" Height="17" Margin="0,0,7,0" />
                    <TextBlock Text="Xác nhận đổi phòng" />
                </StackPanel>
            </Button>
            <Button Margin="10,0,0,0" Style="{StaticResource ActionButton}" Background="#64748B" BorderBrush="#475569" Click="BtnDong_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Close" Width="16" Height="16" Margin="0,0,7,0" />
                    <TextBlock Text="Đóng" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
