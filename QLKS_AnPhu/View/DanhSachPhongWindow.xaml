<Window x:Class="QLKS_AnPhu.View.DanhSachPhongWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Danh sách phòng"
        Width="1080"
        Height="600"
        MinWidth="960"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Grid Margin="18,18,18,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="54" />
            <RowDefinition Height="*" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Danh sách phòng"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="16"
                   Foreground="#0F1F33" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
            <Button Width="112"
                    Height="34"
                    Background="#22C55E"
                    BorderBrush="#22C55E"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Click="BtnThem_Click">
                <TextBlock Text="Thêm" />
            </Button>

            <Button Width="104"
                    Height="34"
                    Margin="12,0,0,0"
                    Background="#F59E0B"
                    BorderBrush="#F59E0B"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Click="BtnSua_Click">
                <TextBlock Text="Sửa" />
            </Button>

            <Button Width="104"
                    Height="34"
                    Margin="12,0,0,0"
                    Background="#EF4444"
                    BorderBrush="#EF4444"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Click="BtnXoa_Click">
                <TextBlock Text="Xóa" />
            </Button>

            <Button Width="132"
                    Height="34"
                    Margin="12,0,0,0"
                    Background="#667085"
                    BorderBrush="#667085"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Click="BtnLamMoi_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Refresh"
                                                Width="14"
                                                Height="14"
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center" />
                    <TextBlock Text="Làm mới" />
                </StackPanel>
            </Button>
        </StackPanel>

        <DataGrid x:Name="DgPhong"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeight="24"
                  FontSize="14"
                  AlternatingRowBackground="#F8FAFC">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Height" Value="38" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Background" Value="#DEE5EE" />
                    <Setter Property="BorderBrush" Value="#AAB4C2" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Số phòng" Binding="{Binding SoPhong}" Width="80" />
                <DataGridTextColumn Header="Tầng" Binding="{Binding Tang}" Width="105" />
                <DataGridTextColumn Header="Loại phòng" Binding="{Binding LoaiPhong}" Width="110" />
                <DataGridTextColumn Header="GiaGio" Binding="{Binding GiaGio, StringFormat={}{0:N0}}" Width="106" />
                <DataGridTextColumn Header="GiaNgay" Binding="{Binding GiaNgay, StringFormat={}{0:N0}}" Width="106" />
                <DataGridTextColumn Header="GiaDem" Binding="{Binding GiaDem, StringFormat={}{0:N0}}" Width="106" />
                <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="108" />
                <DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChu}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="3"
                Width="112"
                Height="34"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,104,0"
                Background="#667085"
                BorderBrush="#667085"
                Foreground="White"
                FontWeight="SemiBold"
                Click="BtnDong_Click">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="×" Margin="0,0,6,0" />
                <TextBlock Text="Đóng" />
            </StackPanel>
        </Button>
    </Grid>
</Window>
