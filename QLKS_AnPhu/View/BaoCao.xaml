<UserControl x:Class="QLKS_AnPhu.View.BaoCao"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1440"
             FontFamily="Segoe UI"
             Background="#F4F7FB"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="TextMainBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B" />
        <SolidColorBrush x:Key="LineBrush" Color="#E2E8F0" />

        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="BorderBrush" Value="#E5EAF2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.11" Color="#1E293B" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KpiCardStyle" TargetType="Border" BasedOn="{StaticResource DashboardCardStyle}">
            <Setter Property="Padding" Value="0" />
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.025" Duration="0:0:0.14" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.025" Duration="0:0:0.14" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.14" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.14" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2563EB" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2563EB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E40AF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#1E40AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1.025" Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1.025" Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>

        <Style x:Key="ReportToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ReportToolbarOutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource ReportToolbarButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
        </Style>

        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="13">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#93C5FD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Root" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="13">
                                            <Grid>
                                                <ContentPresenter Margin="12,0,38,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <Path HorizontalAlignment="Right" Margin="0,0,14,0" VerticalAlignment="Center" Fill="#475569" Data="M 0 0 L 4 4 L 8 0 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="BorderBrush" Value="#93C5FD" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" Margin="12,0,38,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border MinWidth="{TemplateBinding ActualWidth}" MaxHeight="240" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="13" Padding="4">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="42" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="FilterLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style x:Key="ReportDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="RowHeight" Value="44" />
            <Setter Property="ColumnHeaderHeight" Value="46" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderBrush" Value="#1E40AF" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EFF6FF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE" />
                    <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="0" Padding="0" MinHeight="0" Visibility="Collapsed">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F2F6F" Offset="0" />
                    <GradientStop Color="#1D4ED8" Offset="0.55" />
                    <GradientStop Color="#0EA5E9" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center" Visibility="Collapsed">
                    <Border Width="150" Height="30" CornerRadius="15" Background="#FFFFFF22" HorizontalAlignment="Left" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="DatabaseCheck" Width="16" Height="16" Foreground="#DDF7FF" Margin="0,0,6,0" />
                            <TextBlock Text="Dữ liệu trực tiếp" Foreground="#E0F2FE" FontWeight="SemiBold" FontSize="12" />
                        </StackPanel>
                    </Border>
                    <TextBlock Text="BÁO CÁO - THỐNG KÊ KHÁCH SẠN" FontSize="31" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Theo dõi doanh thu, đặt phòng, khách hàng và tình trạng phòng trong một màn hình." Margin="0,8,0,0" FontSize="15" Foreground="#DDEBFF" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                    <Button Style="{StaticResource OutlineButtonStyle}" Margin="0,0,10,0" Click="BtnXuatExcel_Click">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="MicrosoftExcel" Width="18" Height="18" Foreground="#16A34A" Margin="0,0,8,0" />
                            <TextBlock Text="Xuất Excel" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource OutlineButtonStyle}" Click="BtnInBaoCao_Click">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Printer" Width="18" Height="18" Foreground="#475569" Margin="0,0,8,0" />
                            <TextBlock Text="In báo cáo" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource DashboardCardStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Bộ lọc báo cáo" FontSize="19" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
                                <TextBlock Text="Chọn khoảng thời gian và loại báo cáo, sau đó bấm Xem báo cáo." Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource ModernButtonStyle}" Click="BtnXemBaoCao_Click" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="ChartAreaspline" Width="18" Height="18" Margin="0,0,8,0" />
                                    <TextBlock Text="Xem báo cáo" />
                                </StackPanel>
                            </Button>
                        </DockPanel>

                        <WrapPanel Grid.Row="2" ItemHeight="68">
                            <StackPanel Width="210" Margin="0,0,14,0">
                                <TextBlock Text="Từ ngày" Style="{StaticResource FilterLabelStyle}" />
                                <DatePicker x:Name="DpTuNgay" Style="{StaticResource ModernDatePickerStyle}" />
                            </StackPanel>

                            <StackPanel Width="210" Margin="0,0,14,0">
                                <TextBlock Text="Đến ngày" Style="{StaticResource FilterLabelStyle}" />
                                <DatePicker x:Name="DpDenNgay" Style="{StaticResource ModernDatePickerStyle}" />
                            </StackPanel>

                            <StackPanel Width="280" Margin="0,0,14,0">
                                <TextBlock Text="Loại báo cáo" Style="{StaticResource FilterLabelStyle}" />
                                <ComboBox x:Name="CboLoaiBaoCao" Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="0" SelectionChanged="CboLoaiBaoCao_SelectionChanged">
                                    <ComboBoxItem Content="Doanh thu theo ngày" />
                                    <ComboBoxItem Content="Hóa đơn" />
                                    <ComboBoxItem Content="Tình trạng phòng" />
                                    <ComboBoxItem Content="Dịch vụ - vật tư" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,20,10,0">
                                <Button MinWidth="132" Style="{StaticResource ReportToolbarButtonStyle}" Click="BtnXemBaoCao_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="ChartAreaspline" Width="16" Height="16" Margin="0,0,7,0" />
                                        <TextBlock Text="Xem báo cáo" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <StackPanel Margin="0,20,10,0">
                                <Button MinWidth="116" Style="{StaticResource ReportToolbarOutlineButtonStyle}" Click="BtnXuatExcel_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="MicrosoftExcel" Width="16" Height="16" Foreground="#16A34A" Margin="0,0,7,0" />
                                        <TextBlock Text="Xuất Excel" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <StackPanel Margin="0,20,0,0">
                                <Button MinWidth="112" Style="{StaticResource ReportToolbarOutlineButtonStyle}" Click="BtnInBaoCao_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <iconPacks:PackIconMaterial Kind="Printer" Width="16" Height="16" Foreground="#475569" Margin="0,0,7,0" />
                                        <TextBlock Text="In báo cáo" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </WrapPanel>
                    </Grid>
                </Border>

                <UniformGrid Grid.Row="2" Columns="4">
                    <Border Style="{StaticResource KpiCardStyle}" Margin="0,0,14,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#1D4ED8" CornerRadius="16,0,0,16" />
                            <Grid Grid.Column="1" Margin="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Tổng doanh thu" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" />
                                    <TextBlock x:Name="TxtTongDoanhThu" Text="0 đ" Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
                                    <TextBlock x:Name="TxtDoanhThuKyTruoc" Text="Theo khoảng ngày đã chọn" Foreground="#16A34A" FontSize="12" Margin="0,4,0,0" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="54" Height="54" CornerRadius="15" Background="#DBEAFE">
                                    <iconPacks:PackIconMaterial Kind="CashMultiple" Width="29" Height="29" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}" Margin="0,0,14,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#0284C7" CornerRadius="16,0,0,16" />
                            <Grid Grid.Column="1" Margin="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Phòng đã đặt" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" />
                                    <TextBlock x:Name="TxtTongPhongDat" Text="0" Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
                                    <TextBlock Text="Lượt đặt phòng" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="54" Height="54" CornerRadius="15" Background="#E0F2FE">
                                    <iconPacks:PackIconMaterial Kind="CalendarCheck" Width="29" Height="29" Foreground="#0284C7" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}" Margin="0,0,14,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#16A34A" CornerRadius="16,0,0,16" />
                            <Grid Grid.Column="1" Margin="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Tổng khách hàng" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" />
                                    <TextBlock x:Name="TxtTongKhachHang" Text="0" Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
                                    <TextBlock Text="Khách hàng trong hệ thống" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,4,0,0" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="54" Height="54" CornerRadius="15" Background="#DCFCE7">
                                    <iconPacks:PackIconMaterial Kind="AccountGroup" Width="29" Height="29" Foreground="#16A34A" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#7C3AED" CornerRadius="16,0,0,16" />
                            <Grid Grid.Column="1" Margin="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Tỷ lệ lấp đầy" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" />
                                    <TextBlock x:Name="TxtTyLeLapDay" Text="0%" Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
                                    <ProgressBar x:Name="PbTyLeLapDay" Height="7" Margin="0,8,0,0" Value="0" Maximum="100" Foreground="#7C3AED" Background="#EDE9FE" />
                                </StackPanel>
                                <Border Grid.Column="1" Width="54" Height="54" CornerRadius="15" Background="#F5F3FF">
                                    <iconPacks:PackIconMaterial Kind="ChartDonut" Width="29" Height="29" Foreground="#7C3AED" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.7*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource DashboardCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="270" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Doanh thu theo tháng" FontSize="19" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
                                    <TextBlock Text="Di chuột lên từng cột để xem doanh thu chi tiết." Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" />
                                </StackPanel>
                                <Border DockPanel.Dock="Right" Background="#EFF6FF" CornerRadius="12" Padding="12,7" VerticalAlignment="Top">
                                    <TextBlock Text="Theo năm của Từ ngày" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                                </Border>
                            </DockPanel>

                            <Grid Grid.Row="2">
                                <Border Background="#F8FAFC" CornerRadius="14" />
                                <Grid Margin="16,12,16,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="30" />
                                    </Grid.RowDefinitions>
                                    <ItemsControl x:Name="IcDoanhThuThang" VerticalAlignment="Bottom">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="12" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Height="{Binding BarHeight}" Background="{Binding Color}" CornerRadius="9,9,0,0" Margin="6,0" VerticalAlignment="Bottom" ToolTip="{Binding ToolTip}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl x:Name="IcLabelThang" Grid.Row="1">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="12" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Label}" TextAlignment="Center" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource DashboardCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Trạng thái phòng" FontSize="19" FontWeight="Bold" Foreground="{StaticResource TextMainBrush}" />
                                <TextBlock Text="Tổng quan công suất hiện tại." Margin="0,4,0,0" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" VerticalAlignment="Center">
                                <Grid Width="190" Height="190" HorizontalAlignment="Center">
                                    <Ellipse Fill="#E0F2FE" />
                                    <Ellipse Width="144" Height="144" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock x:Name="TxtTyLeLapDayChart" Text="0%" FontSize="30" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" TextAlignment="Center" />
                                        <TextBlock Text="Lấp đầy" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Center" />
                                    </StackPanel>
                                </Grid>

                                <Border Background="#F8FAFC" CornerRadius="14" Padding="14" Margin="0,18,0,0">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="12" Height="12" CornerRadius="6" Background="#1D4ED8" Margin="0,0,8,0" />
                                                <TextBlock Text="Có khách / đã đặt" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <TextBlock x:Name="TxtPhongCoKhach" Text="0" DockPanel.Dock="Right" FontWeight="Bold" />
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="12" Height="12" CornerRadius="6" Background="#0EA5E9" Margin="0,0,8,0" />
                                                <TextBlock Text="Phòng trống" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <TextBlock x:Name="TxtPhongTrong" Text="0" DockPanel.Dock="Right" FontWeight="Bold" />
                                        </DockPanel>
                                        <DockPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="12" Height="12" CornerRadius="6" Background="#94A3B8" Margin="0,0,8,0" />
                                                <TextBlock Text="Bảo trì / khác" Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                            <TextBlock x:Name="TxtPhongBaoTri" Text="0" DockPanel.Dock="Right" FontWeight="Bold" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="6" Style="{StaticResource DashboardCardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="1" />
                            <RowDefinition Height="390" />
                        </Grid.RowDefinitions>

                        <DockPanel Margin="20,16,20,8">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock x:Name="TxtKyBaoCao" Text="Kỳ báo cáo: --/--/---- - --/--/---- / 0 dòng" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextMainBrush}" />
                            </StackPanel>
                            <Grid DockPanel.Dock="Right" Width="340" HorizontalAlignment="Right">
                                <TextBox x:Name="TxtTimKiem" Style="{StaticResource ModernTextBoxStyle}" Padding="42,0,12,0" TextChanged="TxtTimKiem_TextChanged" />
                                <iconPacks:PackIconMaterial Kind="Magnify" Width="20" Height="20" Foreground="{StaticResource TextMutedBrush}" Margin="14,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            </Grid>
                        </DockPanel>

                        <TabControl x:Name="TabBaoCao" Grid.Row="1" Margin="20,0,20,10" SelectionChanged="TabBaoCao_SelectionChanged">
                            <TabItem Header="📈  Doanh thu theo ngày" />
                            <TabItem Header="🧾  Hóa đơn" />
                            <TabItem Header="🛏  Tình trạng phòng" />
                            <TabItem Header="🧰  Dịch vụ - vật tư" />
                        </TabControl>

                        <Border Grid.Row="2" Background="{StaticResource LineBrush}" />

                        <DataGrid Grid.Row="3" x:Name="DgBaoCao" Style="{StaticResource ReportDataGridStyle}" Margin="20,0,20,20" />
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
