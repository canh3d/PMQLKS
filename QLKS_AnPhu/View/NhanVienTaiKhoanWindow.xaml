<Window x:Class="QLKS_AnPhu.View.NhanVienTaiKhoanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Thông tin và tài khoản nhân viên"
        Width="1040"
        Height="650"
        MinWidth="920"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FB"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2556D9" />
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="96" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#163C9B" Offset="0" />
                    <GradientStop Color="#0EA5E9" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="26,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="THÔNG TIN NHÂN VIÊN" FontSize="24" FontWeight="Bold" Foreground="White" />
                    <TextBlock x:Name="TxtSubTitle" Margin="0,6,0,0" FontSize="14" Foreground="#DBEAFE" />
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="42"
                        Height="38"
                        Background="#FFFFFF22"
                        BorderBrush="#FFFFFF55"
                        Foreground="White"
                        Click="BtnDong_Click">
                    <iconPacks:PackIconMaterial Kind="Close" Width="18" Height="18" />
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Border Width="96" Height="96" CornerRadius="48" Background="#DBEAFE" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="AccountTie" Width="52" Height="52" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock x:Name="TxtMaNhanVien" Margin="0,14,0,0" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                    <TextBlock x:Name="TxtHoTen" Margin="0,4,0,20" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="116" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36" />
                            <RowDefinition Height="36" />
                            <RowDefinition Height="36" />
                            <RowDefinition Height="36" />
                            <RowDefinition Height="36" />
                            <RowDefinition Height="36" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Giới tính" Foreground="#64748B" />
                        <TextBlock x:Name="TxtGioiTinh" Grid.Column="1" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Text="Ngày sinh" Foreground="#64748B" />
                        <TextBlock x:Name="TxtNgaySinh" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="2" Text="Số điện thoại" Foreground="#64748B" />
                        <TextBlock x:Name="TxtSDT" Grid.Row="2" Grid.Column="1" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="3" Text="Chức vụ" Foreground="#64748B" />
                        <TextBlock x:Name="TxtChucVu" Grid.Row="3" Grid.Column="1" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="4" Text="Ca gần nhất" Foreground="#64748B" />
                        <TextBlock x:Name="TxtCaLam" Grid.Row="4" Grid.Column="1" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="5" Text="Trạng thái" Foreground="#64748B" />
                        <TextBlock x:Name="TxtTrangThai" Grid.Row="5" Grid.Column="1" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="6" Text="Địa chỉ" Foreground="#64748B" />
                        <TextBlock x:Name="TxtDiaChi" Grid.Row="6" Grid.Column="1" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Tài khoản nhân viên" FontSize="20" FontWeight="Bold" />
                            <TextBlock x:Name="TxtTongTaiKhoan" Margin="0,5,0,0" Foreground="#64748B" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ToolButtonStyle}" Background="{StaticResource PrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" Foreground="White" Click="BtnThemTaiKhoan_Click">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="Plus" Width="16" Height="16" Margin="0,0,6,0" />
                                    <TextBlock Text="Thêm tài khoản" />
                                </StackPanel>
                            </Button>
                            <Button Margin="8,0,0,0" Style="{StaticResource ToolButtonStyle}" Background="White" BorderBrush="#CBD5E1" Click="BtnSuaTaiKhoan_Click" Content="Sửa" />
                            <Button Margin="8,0,0,0" Style="{StaticResource ToolButtonStyle}" Background="White" BorderBrush="#CBD5E1" Foreground="#DC2626" Click="BtnXoaTaiKhoan_Click" Content="Xóa" />
                            <Button Margin="8,0,0,0" Style="{StaticResource ToolButtonStyle}" Background="White" BorderBrush="#CBD5E1" Click="BtnLamMoi_Click" Content="Làm mới" />
                        </StackPanel>
                    </DockPanel>

                    <DataGrid x:Name="DgTaiKhoan"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="None"
                              RowHeight="42"
                              FontSize="14"
                              BorderThickness="0">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Height" Value="40" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Background" Value="#F1F5F9" />
                                <Setter Property="Padding" Value="10,0" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã TK" Binding="{Binding MaTK}" Width="80" />
                            <DataGridTextColumn Header="Tên đăng nhập" Binding="{Binding TenDangNhap}" Width="*" />
                            <DataGridTextColumn Header="Vai trò" Binding="{Binding VaiTro}" Width="130" />
                            <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThaiHienThi}" Width="130" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
