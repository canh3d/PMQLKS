<Window x:Class="QLKS_AnPhu.View.HoaDonChiTietWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Chi tiết hóa đơn"
        Width="1260"
        Height="760"
        MinWidth="1060"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Style>
                <Style TargetType="iconPacks:PackIconMaterial">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Style>
            </Style.Resources>
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="92" />
            <RowDefinition Height="1" />
            <RowDefinition Height="*" />
            <RowDefinition Height="54" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="32" />
                <RowDefinition Height="32" />
            </Grid.RowDefinitions>

            <TextBlock Text="Mã hóa đơn:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtMaHoaDon" Margin="130,0,0,0" FontSize="16" Foreground="#0B2545" />
            <TextBlock Grid.Row="1" Text="Khách hàng:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtKhachHang" Grid.Row="1" Margin="130,0,0,0" FontSize="16" Foreground="#0B2545" />
            <TextBlock Grid.Row="2" Text="Phòng:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtPhong" Grid.Row="2" Margin="130,0,0,0" FontSize="16" Foreground="#0B2545" />

            <TextBlock Grid.Column="1" Text="Ngày lập:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtNgayLap" Grid.Column="1" Margin="130,0,0,0" FontSize="16" Foreground="#0B2545" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="SĐT:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtSdt" Grid.Row="1" Grid.Column="1" Margin="130,0,0,0" FontSize="16" Foreground="#0B2545" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="Loại phòng:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtLoaiPhong" Grid.Row="2" Grid.Column="1" Margin="130,0,0,0" FontSize="16" Foreground="#0B2545" />
        </Grid>

        <Border Grid.Row="1" Background="#D7DEE8" />

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.03*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="0.97*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="42" />
            </Grid.RowDefinitions>

            <TextBlock Text="Thời gian thuê:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtThoiGianThue" Margin="150,0,0,0" FontSize="16" Foreground="#0B2545" />

            <TextBlock Grid.Row="1" Text="Thời lượng:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtThoiLuong" Grid.Row="1" Margin="150,0,0,0" FontSize="16" Foreground="#0B2545" />

            <TextBlock Grid.Row="2" Text="Tiền phòng:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtTienPhong" Grid.Row="2" Margin="150,0,0,0" FontSize="16" Foreground="#0B2545" />

            <TextBlock Grid.Row="3" Text="CHI TIẾT PHỤ PHÍ" FontSize="16" Foreground="#2563EB" />

            <TextBlock Grid.Row="4" Text="Nhận sớm:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtNhanSom" Grid.Row="4" Margin="150,0,0,0" FontSize="16" Foreground="#0B2545" />

            <TextBlock Grid.Row="5" Text="Trả muộn:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtTraMuon" Grid.Row="5" Margin="150,0,0,0" FontSize="16" Foreground="#0B2545" />

            <TextBlock Grid.Row="6" Text="Tổng phụ phí:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtPhuPhi" Grid.Row="6" Margin="150,0,0,0" FontSize="16" Foreground="#0B2545" />

            <TextBlock Grid.Column="2" Text="Trạng thái:" FontSize="16" Foreground="#0F172A" />
            <Border Grid.Column="2" Margin="130,0,0,7" Background="#FEF9C3">
                <TextBlock x:Name="TxtTrangThai" Padding="10,2" FontSize="16" Foreground="#713F12" />
            </Border>

            <TextBlock Grid.Row="6" Grid.Column="2" Text="Giảm giá:" FontSize="16" Foreground="#0F172A" />
            <TextBlock x:Name="TxtGiamGia" Grid.Row="6" Grid.Column="2" Margin="130,0,0,0" FontSize="16" Foreground="#0B2545" />

            <StackPanel Grid.Row="7" Grid.ColumnSpan="3" Margin="4,12,4,0">
                <TextBlock Text="DỊCH VỤ / VẬT TƯ SỬ DỤNG" FontSize="16" Foreground="#2563EB" />
                <DataGrid x:Name="DgDichVu"
                          Margin="0,12,0,0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeight="28"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderBrush="#CBD5E1"
                          BorderThickness="1"
                          Height="180">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Height" Value="32" />
                            <Setter Property="Background" Value="#E5ECF5" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="BorderBrush" Value="#CBD5E1" />
                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding Stt}" Width="64" />
                        <DataGridTextColumn Header="Tên DV/VT" Binding="{Binding TenDichVu}" Width="*" />
                        <DataGridTextColumn Header="SL" Binding="{Binding SoLuong}" Width="110" />
                        <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGiaText}" Width="220" />
                        <DataGridTextColumn Header="Thành tiền" Binding="{Binding ThanhTienText}" Width="220" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <StackPanel Grid.Row="8" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Tổng tiền:" FontSize="18" FontWeight="Bold" Foreground="#0F172A" VerticalAlignment="Center" />
                <TextBlock x:Name="TxtTongTien" Margin="12,0,0,0" FontSize="20" FontWeight="Bold" Foreground="#16A34A" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="BtnThanhToan" Style="{StaticResource ActionButtonStyle}" Background="#22C55E" BorderBrush="#16A34A" Click="BtnThanhToan_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="CashCheck" Width="14" Height="14" Margin="0,0,7,0" />
                    <TextBlock Text="Thanh toán" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource ActionButtonStyle}" Margin="10,0,0,0" Background="#F59E0B" BorderBrush="#D97706" Click="BtnInHoaDon_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Printer" Width="14" Height="14" Margin="0,0,7,0" />
                    <TextBlock Text="In hóa đơn" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource ActionButtonStyle}" Margin="10,0,0,0" Background="#64748B" BorderBrush="#475569" Click="BtnDong_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14" Margin="0,0,7,0" />
                    <TextBlock Text="Đóng" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
