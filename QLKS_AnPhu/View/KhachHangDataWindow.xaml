<Window x:Class="QLKS_AnPhu.View.KhachHangDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dữ liệu khách hàng"
        Width="980"
        Height="560"
        MinWidth="820"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="*" />
            <RowDefinition Height="44" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="TxtTieuDe" FontSize="22" FontWeight="Bold" Foreground="#0F1F33" />
            <TextBlock x:Name="TxtThongBao" Margin="0,8,0,0" FontSize="13" Foreground="#667085" TextWrapping="Wrap" />
        </StackPanel>

        <DataGrid x:Name="DgData"
                  Grid.Row="1"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F8FAFC"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto" />

        <Button Grid.Row="2"
                Width="104"
                Height="34"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="#667085"
                BorderBrush="#667085"
                Foreground="White"
                FontWeight="SemiBold"
                Click="BtnDong_Click"
                Content="Đóng" />
    </Grid>
</Window>
