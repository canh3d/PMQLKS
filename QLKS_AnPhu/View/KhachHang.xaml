<UserControl x:Class="QLKS_AnPhu.View.KhachHang"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="873.846"
             d:DesignWidth="1400"
             Background="#F7F8FA"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <SolidColorBrush x:Key="HeaderBrush" Color="#0F3555" />
        <SolidColorBrush x:Key="HeaderAccentBrush" Color="#0B4EA2" />
        <SolidColorBrush x:Key="TextMainBrush" Color="#111827" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#667085" />
        <SolidColorBrush x:Key="BlueBrush" Color="#0F3B62" />
        <SolidColorBrush x:Key="PrimaryBrushLocal" Color="#2563EB" />
        <SolidColorBrush x:Key="GreenBrush" Color="#1F8E52" />
        <SolidColorBrush x:Key="RedBrush" Color="#B32835" />
        <SolidColorBrush x:Key="GrayBrush" Color="#667085" />
        <SolidColorBrush x:Key="VipBrush" Color="#B6732B" />

        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAFAFA" />
            <Setter Property="BorderBrush" Value="#D8DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Style>
                <Style TargetType="iconPacks:PackIconMaterial">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Style>
            </Style.Resources>
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#E5E7EB" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#CBD5E1" />
                                <Setter Property="Foreground" Value="#64748B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LargeActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
            <Setter Property="Height" Value="46" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="DetailTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18,12,18,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="0" />
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#102D49" Offset="0" />
                    <GradientStop Color="#0F3555" Offset="0.55" />
                    <GradientStop Color="#0B4EA2" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Margin="18,12,0,0" Visibility="Collapsed">
                <TextBlock Text="QUẢN LÝ KHÁCH HÀNG"
                           FontSize="23"
                           FontWeight="SemiBold"
                           Foreground="#DCE7F3" />
                <TextBlock Text="Theo dõi thông tin khách hàng dựa trên dữ liệu thực tế"
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="#B7C4D2" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="104" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="106" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="124" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="112" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtTimKiem"
                     Grid.Column="0"
                     Height="32"
                     Padding="34,0,12,0"
                     VerticalContentAlignment="Center"
                     FontSize="13"
                     KeyDown="TxtTimKiem_KeyDown" />
            <iconPacks:PackIconMaterial Grid.Column="0"
                                        Kind="Magnify"
                                        Width="14"
                                        Height="14"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="12,0,0,0"
                                        Foreground="#667085"
                                        IsHitTestVisible="False" />

            <Button Grid.Column="2"
                    Style="{StaticResource ToolButtonStyle}"
                    Background="{StaticResource BlueBrush}"
                    BorderBrush="{StaticResource BlueBrush}"
                    Foreground="White"
                    Click="BtnTimKiem_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Magnify" Width="14" Height="14" Margin="0,0,6,0" />
                    <TextBlock Text="Tìm kiếm" />
                </StackPanel>
            </Button>

            <Button Grid.Column="4"
                    Style="{StaticResource ToolButtonStyle}"
                    Background="White"
                    BorderBrush="#CBD5E1"
                    Foreground="#334155"
                    Click="BtnLamMoi_Click">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,6,0" />
                    <TextBlock Text="Làm mới" />
                </StackPanel>
            </Button>

            <Button Grid.Column="6"
                    Style="{StaticResource ToolButtonStyle}"
                    Background="#0F4C81"
                    BorderBrush="#0F4C81"
                    Foreground="White"
                    Click="BtnLocThuong_Click"
                    Content="Khách thường" />

            <Button Grid.Column="8"
                    Style="{StaticResource ToolButtonStyle}"
                    Background="{StaticResource VipBrush}"
                    BorderBrush="{StaticResource VipBrush}"
                    Foreground="White"
                    Click="BtnLocVip_Click"
                    Content="Khách VIP" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.72*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="14" />
                <RowDefinition Height="74" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="62" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="16,10,16,0">
                        <StackPanel>
                            <TextBlock Text="Danh sách khách hàng" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextMainBrush}" />
                            <TextBlock x:Name="TxtTongDong" Margin="0,5,0,0" FontSize="13" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="TxtLoi" Margin="0,3,0,0" FontSize="12" Foreground="#EF4444" TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                            <Button Width="122"
                                    Style="{StaticResource ToolButtonStyle}"
                                    Background="#1D5E91"
                                    BorderBrush="#1D5E91"
                                    Foreground="White"
                                    Click="BtnThem_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="PlusCircle" Width="14" Height="14" Margin="0,0,6,0" />
                                    <TextBlock Text="Thêm khách" />
                                </StackPanel>
                            </Button>
                            <Button Width="78"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource ToolButtonStyle}"
                                    Background="White"
                                    BorderBrush="#CBD5E1"
                                    Foreground="#334155"
                                    Click="BtnSua_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="PencilBoxOutline" Width="14" Height="14" Margin="0,0,5,0" />
                                    <TextBlock Text="Sửa" />
                                </StackPanel>
                            </Button>
                            <Button Width="78"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource ToolButtonStyle}"
                                    Background="{StaticResource RedBrush}"
                                    BorderBrush="{StaticResource RedBrush}"
                                    Foreground="White"
                                    Click="BtnXoa_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Delete" Width="14" Height="14" Margin="0,0,5,0" />
                                    <TextBlock Text="Xóa" />
                                </StackPanel>
                            </Button>
                            <Button Width="104"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource ToolButtonStyle}"
                                    Background="White"
                                    BorderBrush="#CBD5E1"
                                    Foreground="#334155"
                                    Click="BtnLamMoi_Click">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14" Margin="0,0,5,0" />
                                    <TextBlock Text="Làm mới" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="DgKhachHang"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="34"
                              FontSize="13"
                              BorderThickness="0"
                              AlternationCount="2"
                              AlternatingRowBackground="#F8FAFC"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              SelectionChanged="DgKhachHang_SelectionChanged">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Height" Value="34" />
                                <Setter Property="FontSize" Value="13" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Foreground" Value="#334155" />
                                <Setter Property="Background" Value="#EEF2F7" />
                                <Setter Property="BorderBrush" Value="#CBD5E1" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White" />
                                <Setter Property="Foreground" Value="#334155" />
                                <Setter Property="SnapsToDevicePixels" Value="True" />
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F8FAFC" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EEF4FF" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#DBEAFE" />
                                        <Setter Property="Foreground" Value="#111827" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã KH" Binding="{Binding Ma}" Width="62" />
                            <DataGridTextColumn Header="Họ tên khách hàng" Binding="{Binding HoTen}" Width="180" />
                            <DataGridTextColumn Header="Giới tính" Binding="{Binding GioiTinh}" Width="88" />
                            <DataGridTextColumn Header="Ngày sinh" Binding="{Binding NgaySinhHienThi}" Width="112" />
                            <DataGridTextColumn Header="Số điện thoại" Binding="{Binding SDT}" Width="128" />
                            <DataGridTextColumn Header="CCCD/CMND" Binding="{Binding CCCD}" Width="132" />
                            <DataGridTextColumn Header="Địa chỉ" Binding="{Binding DiaChi}" Width="150" />
                            <DataGridTextColumn Header="Loại khách hàng" Binding="{Binding LoaiKhach}" Width="132" />
                            <DataGridTextColumn Header="Ghi chú" Binding="{Binding GhiChu}" Width="170" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource PanelStyle}" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource LargeActionButtonStyle}" Background="{StaticResource GreenBrush}" BorderBrush="{StaticResource GreenBrush}" Foreground="White" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="MicrosoftExcel" Width="17" Height="17" Margin="0,0,8,0" />
                            <TextBlock Text="Xuất Excel" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Style="{StaticResource LargeActionButtonStyle}" Background="{StaticResource RedBrush}" BorderBrush="{StaticResource RedBrush}" Foreground="White" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="FilePdfBox" Width="17" Height="17" Margin="0,0,8,0" />
                            <TextBlock Text="Xuất PDF" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4" Style="{StaticResource LargeActionButtonStyle}" Background="{StaticResource GrayBrush}" BorderBrush="{StaticResource GrayBrush}" Foreground="White" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Printer" Width="17" Height="17" Margin="0,0,8,0" />
                            <TextBlock Text="In danh sách" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PanelStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="CHI TIẾT KHÁCH HÀNG" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextMainBrush}" />

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36" />
                            <RowDefinition Height="36" />
                            <RowDefinition Height="36" />
                            <RowDefinition Height="36" />
                            <RowDefinition Height="36" />
                            <RowDefinition Height="36" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Account" Width="14" Height="14" Margin="0,0,7,0" Foreground="#667085" />
                            <TextBlock Text="Mã khách hàng" FontSize="13" />
                        </StackPanel>
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource DetailTextBoxStyle}" Text="{Binding Ma}" />

                        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Account" Width="14" Height="14" Margin="0,0,7,0" Foreground="#667085" />
                            <TextBlock Text="Họ tên khách ..." FontSize="13" />
                        </StackPanel>
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource DetailTextBoxStyle}" Text="{Binding HoTen}" />

                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="HumanMaleFemale" Width="14" Height="14" Margin="0,0,7,0" Foreground="#667085" />
                            <TextBlock Text="Giới tính" FontSize="13" />
                        </StackPanel>
                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource DetailTextBoxStyle}" Text="{Binding GioiTinh}" />

                        <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="Phone" Width="14" Height="14" Margin="0,0,7,0" Foreground="#667085" />
                            <TextBlock Text="Số điện thoại" FontSize="13" />
                        </StackPanel>
                        <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource DetailTextBoxStyle}" Text="{Binding SDT}" />

                        <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="CardAccountDetails" Width="14" Height="14" Margin="0,0,7,0" Foreground="#667085" />
                            <TextBlock Text="CCCD/CMND" FontSize="13" />
                        </StackPanel>
                        <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource DetailTextBoxStyle}" Text="{Binding CCCD}" />

                        <StackPanel Grid.Row="5" Orientation="Horizontal" VerticalAlignment="Center">
                            <iconPacks:PackIconMaterial Kind="MapMarker" Width="14" Height="14" Margin="0,0,7,0" Foreground="#667085" />
                            <TextBlock Text="Địa chỉ" FontSize="13" />
                        </StackPanel>
                        <Grid Grid.Row="5" Grid.Column="1">
                            <TextBox Style="{StaticResource DetailTextBoxStyle}" Text="{Binding DiaChi}" Padding="8,0,54,0" />
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Background="#D9B77A" CornerRadius="12" Padding="13,3">
                                <TextBlock Text="{Binding LoaiKhach}" FontSize="11" Foreground="#5C3B12" />
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="NoteText" Width="15" Height="15" Margin="0,0,7,0" Foreground="#667085" />
                                <TextBlock Text="Ghi chú tổng hợp" FontSize="13" />
                            </StackPanel>
                            <Border Margin="0,5,0,0" BorderBrush="#C8CDD5" BorderThickness="1" Padding="6">
                                <TextBox x:Name="TxtGhiChuTongHop"
                                         Height="116"
                                         Text="{Binding GhiChu, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         BorderBrush="#C8CDD5"
                                         Background="#FAFAFA"
                                         LostFocus="TxtGhiChuTongHop_LostFocus" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource PanelStyle}" Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource LargeActionButtonStyle}" Background="{StaticResource GreenBrush}" BorderBrush="{StaticResource GreenBrush}" Foreground="White" VerticalAlignment="Center" Click="BtnLichSu_Click">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="History" Width="20" Height="20" HorizontalAlignment="Center" />
                            <TextBlock Text="Lịch sử" Margin="0,1,0,0" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Style="{StaticResource LargeActionButtonStyle}" Background="{StaticResource RedBrush}" BorderBrush="{StaticResource RedBrush}" Foreground="White" VerticalAlignment="Center" Click="BtnHoaDon_Click">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="FileDocument" Width="20" Height="20" HorizontalAlignment="Center" />
                            <TextBlock Text="Hóa đơn" Margin="0,1,0,0" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4" Style="{StaticResource LargeActionButtonStyle}" Background="#6B7280" BorderBrush="#6B7280" Foreground="White" VerticalAlignment="Center" Click="BtnDatPhong_Click">
                        <StackPanel>
                            <iconPacks:PackIconMaterial Kind="Calendar" Width="20" Height="20" HorizontalAlignment="Center" />
                            <TextBlock Text="Đặt" Margin="0,1,0,0" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
