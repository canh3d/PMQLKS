<Window x:Class="QLKS_AnPhu.View.HoaDonPrintWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Bill thanh toán"
        Width="1040"
        Height="835"
        MinWidth="900"
        MinHeight="720"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Window.Resources>
        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Style>
                <Style TargetType="iconPacks:PackIconMaterial">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Style>
            </Style.Resources>
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="62" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#F8FAFC" Margin="0">
            <TextBlock Text="HÓA ĐƠN THANH TOÁN"
                       Margin="26,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="16"
                       Foreground="#0B2545" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                <Button Width="92" Style="{StaticResource TopButtonStyle}" Background="#22C55E" BorderBrush="#16A34A" Click="BtnIn_Click">
                    <TextBlock Text="In" />
                </Button>
                <Button Width="120" Margin="12,0,0,0" Style="{StaticResource TopButtonStyle}" Background="#2563EB" BorderBrush="#1D4ED8" Click="BtnXuatAnh_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Image" Width="14" Height="14" Margin="0,0,6,0" />
                        <TextBlock Text="Xuất ảnh" />
                    </StackPanel>
                </Button>
                <Button Width="132" Margin="12,0,0,0" Style="{StaticResource TopButtonStyle}" Background="#F59E0B" BorderBrush="#D97706" Click="BtnXuatExcel_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="MicrosoftExcel" Width="14" Height="14" Margin="0,0,6,0" />
                        <TextBlock Text="Xuất Excel" />
                    </StackPanel>
                </Button>
                <Button Width="88" Margin="12,0,0,0" Style="{StaticResource TopButtonStyle}" Background="#64748B" BorderBrush="#475569" Click="BtnDong_Click">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Close" Width="13" Height="13" Margin="0,0,6,0" />
                        <TextBlock Text="Đóng" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="White">
            <Border x:Name="InvoicePaper"
                    Width="860"
                    MinHeight="710"
                    Padding="46,52"
                    Background="White"
                    HorizontalAlignment="Center"
                    Margin="22,0">
                <StackPanel x:Name="PrintSurface">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="KHÁCH SẠN AN PHÚ" FontSize="24" FontWeight="Bold" Foreground="#0B2545" />
                            <TextBlock x:Name="TxtNgayLap" Margin="0,42,0,0" FontSize="16" Foreground="#0F172A" />
                            <TextBlock x:Name="TxtMaHoaDon" Margin="0,8,0,0" FontSize="16" Foreground="#0F172A" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="18,24,0,0">
                            <TextBlock x:Name="TxtTieuDeHoaDon" Text="Hóa đơn" FontSize="30" FontWeight="SemiBold" Foreground="#0B2545" HorizontalAlignment="Center" />
                            <TextBlock x:Name="TxtSoPhong" Margin="0,24,0,0" FontSize="16" Foreground="#0F172A" />
                            <TextBlock Text="Người lập: admin" Margin="0,8,0,0" FontSize="16" Foreground="#0F172A" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,30,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtKhachHang" FontSize="24" FontWeight="Bold" Foreground="#0B2545" />
                        <TextBlock x:Name="TxtSdt" Grid.Column="1" FontSize="16" Foreground="#0F172A" VerticalAlignment="Bottom" />
                    </Grid>

                    <Border Margin="0,24,0,0" BorderBrush="#94A3B8" BorderThickness="0,1,0,0" />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="88" />
                            <ColumnDefinition Width="248" />
                            <ColumnDefinition Width="112" />
                            <ColumnDefinition Width="58" />
                            <ColumnDefinition Width="132" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Phòng" FontSize="16" Foreground="#334155" />
                        <TextBlock Grid.Column="1" Text="Dịch vụ / vật tư" FontSize="16" Foreground="#334155" />
                        <TextBlock Grid.Column="2" Text="Đơn giá" FontSize="16" Foreground="#334155" />
                        <TextBlock Grid.Column="3" Text="SL" FontSize="16" Foreground="#334155" />
                        <TextBlock Grid.Column="4" Text="Thành tiền" FontSize="16" Foreground="#334155" />
                        <TextBlock Grid.Column="5" Text="Tổng phòng" FontSize="16" Foreground="#334155" />
                    </Grid>

                    <Border Margin="0,12,0,0" BorderBrush="#94A3B8" BorderThickness="0,1,0,0" />

                    <ItemsControl x:Name="ItemsPhongHoaDon" Margin="0,14,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="248" />
                                        <ColumnDefinition Width="112" />
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="132" />
                                        <ColumnDefinition Width="130" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding SoPhong}" FontSize="22" FontWeight="Bold" Foreground="#0B2545" TextWrapping="Wrap" />
                                    <ItemsControl Grid.Column="1" Grid.ColumnSpan="4" ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="248" />
                                                        <ColumnDefinition Width="112" />
                                                        <ColumnDefinition Width="58" />
                                                        <ColumnDefinition Width="132" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Ten}" FontSize="16" Foreground="#0F172A" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="1" Text="{Binding DonGiaText}" FontSize="16" Foreground="#0F172A" />
                                                    <TextBlock Grid.Column="2" Text="{Binding SoLuongText}" FontSize="16" Foreground="#0F172A" />
                                                    <TextBlock Grid.Column="3" Text="{Binding ThanhTienText}" FontSize="16" Foreground="#0F172A" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Grid.Column="5" Text="{Binding TongPhongText}" FontSize="22" FontWeight="Bold" Foreground="#0B2545" TextAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Margin="0,10,0,0" BorderBrush="#94A3B8" BorderThickness="0,1,0,0" />

                    <StackPanel Margin="0,38,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Tổng tiền:" FontSize="24" FontWeight="Bold" Foreground="#0B2545" />
                        <TextBlock x:Name="TxtTongTien" Margin="32,0,0,0" FontSize="24" FontWeight="Bold" Foreground="#0B2545" />
                    </StackPanel>

                    <Border Margin="0,38,0,0" BorderBrush="#94A3B8" BorderThickness="0,1,0,0" />

                    <Grid Margin="0,36,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Cảm ơn quý khách!" FontSize="24" FontWeight="Bold" Foreground="#0B2545" />
                        <TextBlock Grid.Column="1"
                                   Text="Email: hotel@example.com   |   Hotline: ..."
                                   FontSize="16"
                                   Foreground="#0F172A"
                                   VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
